local PremHist = { pos={}, spd={}, accel={}, curve={} }
local MAX_PREM_HIST = 18

local function resetPremHistory()
    PremHist.pos={}; PremHist.spd={}; PremHist.accel={}; PremHist.curve={}
end

local function pushPremHist(dist, vel, t)
    local spd = vel.Magnitude
    table.insert(PremHist.pos,   {d=dist, t=t})
    table.insert(PremHist.spd,   {s=spd,  t=t})
    table.insert(PremHist.accel, {s=spd,  t=t})
    table.insert(PremHist.curve, {v=vel,  t=t})
    if #PremHist.pos   > MAX_PREM_HIST then table.remove(PremHist.pos,1)   end
    if #PremHist.spd   > MAX_PREM_HIST then table.remove(PremHist.spd,1)   end
    if #PremHist.accel > MAX_PREM_HIST then table.remove(PremHist.accel,1) end
    if #PremHist.curve > MAX_PREM_HIST then table.remove(PremHist.curve,1) end
end

local function premLSQRate()   return lsqClosingRate()  end
local function premAccel()     return estimateAccel()    end
local function premCurveRate() return detectCurveRate()  end
local function premSpikeMul()  return detectSpeedSpike() end

local function premFireDist(speed, closingRate, pingComp, curveRate, hitboxTarget)
    local base = hitboxTarget + pingComp + P.EarlyOffset

    if speed > 220 then base += (speed-220)*0.041
    elseif speed > 160 then base += (speed-160)*0.029
    elseif speed > 100 then base += (speed-100)*0.019
    elseif speed >  60 then base += (speed- 60)*0.012 end

    if closingRate > 30 then base += (closingRate-30)*0.068 end

    if curveRate > 3.5 then
        base += math.min((curveRate-3.5)*0.038, 3.4)
    end

    return base
end

local function StartPremiumEngine()
    if PremConn.Parry then PremConn.Parry:Disconnect() end
    resetPremHistory()
    BuildParryIndicator()

    PremConn.Parry = RunService.PreSimulation:Connect(function()
        if not P.AutoParry then return end
        updateSmoothedPing()

        local Ball = GetBall()
        if not Ball then resetPremHistory(); return end

        local HRP = GetHRP()
        if not HRP then return end

        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local tgt = Ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if isTgt and P.AutoFace then
            HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X, HPos.Y, BPos.Z))
        end

        if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then
