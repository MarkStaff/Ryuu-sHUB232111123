-- FREE ENGINE
-- ══════════════════════════════════════════════════════════════════
local FreeHist = { pos={}, accel={}, curve={}, speed={} }
local MAX_FREE_HIST = 14

local function resetFreeHistory()
    FreeHist.pos={}; FreeHist.accel={}; FreeHist.curve={}; FreeHist.speed={}
end

local function pushHist(dist, vel, t)
    local spd = vel.Magnitude
    table.insert(FreeHist.pos,   {d = dist, t = t})
    table.insert(FreeHist.accel, {s = spd,  t = t})
    table.insert(FreeHist.curve, {v = vel,  t = t})
    table.insert(FreeHist.speed, spd)
    if #FreeHist.pos   > MAX_FREE_HIST then table.remove(FreeHist.pos,1)   end
    if #FreeHist.accel > MAX_FREE_HIST then table.remove(FreeHist.accel,1) end
    if #FreeHist.curve > MAX_FREE_HIST then table.remove(FreeHist.curve,1) end
    if #FreeHist.speed > MAX_FREE_HIST then table.remove(FreeHist.speed,1) end
end

local function lsqClosingRate()
    local n = #FreeHist.pos
    if n < 3 then return 0 end
    local sx,sy,sxy,sxx,sw = 0,0,0,0,0
    local t0 = FreeHist.pos[1].t
    for i,p in ipairs(FreeHist.pos) do
        local w = math.exp((i - n) * 0.25)
        local x = p.t - t0
        sx += w*x; sy += w*p.d; sxy += w*x*p.d; sxx += w*x*x; sw += w
    end
    local denom = sw*sxx - sx*sx
    if math.abs(denom) < 1e-6 then return 0 end
    return -(sw*sxy - sx*sy) / denom
end

local function estimateAccel()
    local n = #FreeHist.accel
    if n < 4 then return 0 end
    local sx,sy,sxy,sxx = 0,0,0,0
    local t0 = FreeHist.accel[1].t
    for _,p in ipairs(FreeHist.accel) do
        local x = p.t - t0
        sx += x; sy += p.s; sxy += x*p.s; sxx += x*x
    end
    local denom = n*sxx - sx*sx
    if math.abs(denom) < 1e-6 then return 0 end
    return (n*sxy - sx*sy) / denom
end

local function detectCurveRate()
    local n = #FreeHist.curve
    if n < 3 then return 0 end
    local totalAngle, totalTime = 0, 0
    local startI = math.max(2, n - 4)
    for i = startI, n do
        local a = FreeHist.curve[i-1]
        local b = FreeHist.curve[i]
        if a.v.Magnitude > 1 and b.v.Magnitude > 1 then
            local dot = math.clamp(a.v:Dot(b.v)/(a.v.Magnitude*b.v.Magnitude), -1, 1)
            local dt = b.t - a.t
            if dt > 0 then
                local w = 0.5 + (i - startI) / math.max(n - startI, 1) * 0.5
                totalAngle += math.deg(math.acos(dot)) * w
                totalTime += dt * w
            end
        end
    end
    return totalTime > 0 and totalAngle / totalTime or 0
end

local function detectSpeedSpike()
    local n = #FreeHist.speed
    if n < 5 then return 1.0 end
    local cur = FreeHist.speed[n]
    local prev = FreeHist.speed[n-3]
    if prev and prev > 0 then
        local ratio = cur / prev
        if ratio > 1.65 then return 1.32 end
        if ratio > 1.35 then return 1.18 end
        if ratio > 1.12 then return 1.08 end
    end
    return 1.0
end

local function adaptiveFireDist(speed, closingRate, pingComp, curveRate)
    local base = math.max(speed / 60, 11) + pingComp + S.EarlyOffset

    if speed > 250 then base += (speed - 250) * 0.055
    elseif speed > 180 then base += (speed - 180) * 0.041
    elseif speed > 120 then base += (speed - 120) * 0.028 end

    if closingRate > 50 then base += (closingRate - 50) * 0.083
    elseif closingRate > 28 then base += (closingRate - 28) * 0.048 end

    if curveRate > 6 then
        base += math.min((curveRate - 6) * 0.072, 5.2)
    end

    return base
end

local function StartFreeEngine()
    if Conn.Parry then Conn.Parry:Disconnect() end
    resetFreeHistory()
    BuildParryIndicator()

    Conn.Parry = RunService.PreSimulation:Connect(function()
        if not S.AutoParry then return end
        updateSmoothedPing()

        local Ball = GetBall()
        if not Ball then resetFreeHistory(); return end

        local HRP = GetHRP()
        if not HRP then return end

        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local now = os.clock()
        local tgt = Ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if isTgt and S.AutoFace then
            HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X, HPos.Y, BPos.Z))
        end

        if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then
            S.DidParry = false; return
        end

        local emergencyDist = 6.2 + smoothedPing * 95
        if S.EmergencyParry and isTgt and not S.DidParry and Dist <= emergencyDist then
            FireParry(Ball)
            resetFreeHistory()
            UpdateParryIndicator(Dist, Dist, true)
            return
        end

        if not isTgt then
            resetFreeHistory()
            UpdateParryIndicator(99, 1, false)
            return
        end
        if S.DidParry then return end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        pushHist(Dist, Vel, now)

        local accel = estimateAccel()
        local curveRate = detectCurveRate()
        local closingRate = lsqClosingRate()
        local spikeMul = detectSpeedSpike()

        local projSpeed = (Speed + math.max(0, accel) * 0.04) * spikeMul
        local pingComp = smoothedPing * projSpeed * 1.42
        if smoothedPing > 0.13 then pingComp *= 1.20 end

        local fireDist = adaptiveFireDist(projSpeed, closingRate, pingComp, curveRate)

        UpdateParryIndicator(Dist, fireDist, false)

        if Dist <= fireDist then
            FireParry(Ball)
            resetFreeHistory()
            UpdateParryIndicator(Dist, fireDist, true)
            return
        end
    end)
end

local function StopFreeEngine()
    if Conn.Parry then Conn.Parry:Disconnect(); Conn.Parry = nil end
    resetFreeHistory()
    S.DidParry = false
end

