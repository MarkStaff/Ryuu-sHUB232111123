                ScanBeam.Visible=true; ScanBeam.Position=UDim2.new(0,28,0,92)
                TweenService:Create(ScanBeam,TweenInfo.new(1.4,Enum.EasingStyle.Quad,Enum.EasingDirection.InOut),
                    {Position=UDim2.new(1,-38,0,92)}):Play()

                -- Cycle card stroke through spectrum during scan
                local scanning=true
                task.spawn(function()
                    local t=0
