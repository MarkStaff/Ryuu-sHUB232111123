-- PREMIUM PARRY ENGINE (Advanced)

local PREM_PING_LEAD = 0.75

local PrevVel = nil
local SpeedHistory = {}

local function StartPremiumEngine()

    if PremConn.Parry then
        PremConn.Parry:Disconnect()
    end

    BuildParryIndicator()

    PremConn.Parry = RunService.PreSimulation:Connect(function()

        if not P.AutoParry then return end

        local Ball = GetBall()
        if not Ball then return end

        local HRP = GetHRP()
        if not HRP then return end

        local BPos = Ball.Position
        local HPos = HRP.Position

        local Dist = (HPos - BPos).Magnitude

        local tgt = Ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if not isTgt then
            UpdateParryIndicator(99,1,false)
            return
        end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        -- store speed history
        table.insert(SpeedHistory,Speed)
        if #SpeedHistory > 6 then
            table.remove(SpeedHistory,1)
        end

        -- acceleration prediction
        local accel = 0
        if #SpeedHistory >= 3 then
            accel = SpeedHistory[#SpeedHistory] - SpeedHistory[#SpeedHistory-2]
        end

        local predictedSpeed = Speed + math.max(accel,0)

        local toPlayer = HPos - BPos
        local dotVal = Vel:Dot(toPlayer)

        local isClosing = dotVal > -(Speed*0.22)

        -- curve detection
        local curveBonus = 1

        if PrevVel then

            local angle = Vel.Unit:Dot(PrevVel.Unit)

            if angle < 0.94 then
                curveBonus = 1.18
            elseif angle < 0.97 then
                curveBonus = 1.10
            end
        end

        PrevVel = Vel

        -- dynamic hitbox
        local baseHitbox = P.HitboxTarget or 4

        local dynamicHitbox =
            baseHitbox +
            math.clamp(predictedSpeed/220,0,1)*3

        dynamicHitbox = dynamicHitbox * curveBonus

        -- ping lead
        local pingLead =
            (PingRaw/1000)*
            predictedSpeed*
            PREM_PING_LEAD

        pingLead = math.min(pingLead,2.5)

        local fireDist = dynamicHitbox + pingLead

        UpdateParryIndicator(Dist,fireDist,false)

        -- panic protection
        local panicDist = math.clamp(2 + Speed*0.004,2,3.5)

        if Dist <= panicDist then
            PremiumFire(Ball)
            UpdateParryIndicator(Dist,panicDist,true)
            return
        end

        -- normal fire
        if isClosing and Dist <= fireDist then
            PremiumFire(Ball)
            UpdateParryIndicator(Dist,fireDist,true)
            return
        end

        -- advanced prediction
        if Speed > 70 then

            local dt = 1/60

            local maxFrames =
                Speed > 250 and 6
                or Speed > 180 and 5
                or Speed > 130 and 4
                or 3

            for step=1,maxFrames do

                local nextPos = BPos + Vel*(dt*step)

                if (HPos-nextPos).Magnitude <= fireDist then

                    PremiumFire(Ball)
                    UpdateParryIndicator(Dist,fireDist,true)
                    return
                end
            end
        end

