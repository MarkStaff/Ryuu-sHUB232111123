local function RunDetector(sigList, fireFn)
    local lastTick=0
    local conn
    conn=RunService.Heartbeat:Connect(function()
        local now=os.clock()
        if now-lastTick<0.05 then return end  -- throttle to 20 Hz
        lastTick=now
        pcall(function()
            local ball=GetBall(); if not ball then return end
            local tgt=ball:GetAttribute("target"); if not tgt then return end
            local myHRP=GetHRP(); if not myHRP then return end
            for _,p in ipairs(Players:GetPlayers()) do
                if p==Plr then continue end
                local char=p.Character; if not char then continue end
                local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then continue end
                if (myHRP.Position-hrp.Position).Magnitude>100 then continue end
                local ballNearEnemy=(hrp.Position-ball.Position).Magnitude<20
                local ballTargetsMe=tgt==Plr.Name
                if not (ballNearEnemy or ballTargetsMe) then continue end
                local cdKey=p.Name
                if Det.cds[cdKey] and now-Det.cds[cdKey]<Det.cd then continue end
                for _,sig in ipairs(sigList) do
                    if sig.check(char,p) then
                        Det.cds[cdKey]=now
                        fireFn()  -- no notification — caused frame drops
                        break
                    end
                end
            end
        end)
    end)
    return conn
end

