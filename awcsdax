local function PremRefreshBB(plr)
    if not (plr and plr.Character) then return end
    local entry=PremAbilityBBs[plr]; if not entry then return end
    local head=plr.Character:FindFirstChild("Head"); if not head then return end
    if not entry.bb or not entry.bb.Parent or entry.bb.Parent~=head then
        PremBuildBB(plr); entry=PremAbilityBBs[plr]; if not entry then return end
    end
    local abilityName=ScanAbility(plr)
    local displayName=abilityName or "No Ability"
    if entry.lastAbility==displayName then return end
    entry.lastAbility=displayName

    local bg=entry.bb:FindFirstChildOfClass("Frame"); if not bg then return end
    local aL=bg:FindFirstChild("A"); if not aL then return end
    local sk=bg:FindFirstChild("S")
    local ib=bg:FindFirstChild("IB"); if not ib then return end
    local img=ib:FindFirstChild("IMG")
    local tf=ib:FindFirstChild("TF")
    local iSk=ib:FindFirstChild("IS")

    local data=abilityName and BB_ABILITIES[abilityName]
    if data then
        local tc=TIER_COLORS[data.tier] or Color3.fromRGB(160,90,255)
        local warn=data.warn
        aL.Text=(warn and "⚠ " or "")..abilityName
        aL.TextColor3=warn and Color3.fromRGB(255,70,70) or tc
        if sk then sk.Color=warn and Color3.fromRGB(200,40,40)
            or Color3.fromRGB(math.floor(tc.R*128),math.floor(tc.G*128),math.floor(tc.B*128)) end
        if iSk then iSk.Color=warn and Color3.fromRGB(200,40,40) or tc end
        -- Show image or tier letter
        local imgId=ABILITY_IMAGES[abilityName]
        if imgId and imgId>0 then
            if img then img.Image="rbxassetid://"..imgId; img.ImageTransparency=0
                img.ImageColor3=warn and Color3.fromRGB(255,180,180) or Color3.new(1,1,1) end
            if tf then tf.Visible=false end
        else
            if img then img.ImageTransparency=1 end
            if tf then tf.Visible=true; tf.Text=data.tier
                tf.TextColor3=warn and Color3.fromRGB(255,100,100) or tc end
        end
    else
        aL.Text=abilityName or "No Ability"; aL.TextColor3=Color3.fromRGB(80,75,100)
        if sk then sk.Color=Color3.fromRGB(30,18,55) end
        if img then img.ImageTransparency=1 end
        if iSk then iSk.Color=Color3.fromRGB(50,30,90) end
        if tf then tf.Visible=true; tf.Text="?"; tf.TextColor3=Color3.fromRGB(80,75,100) end
    end
end


local function StartPremAbilityESP()
    PremAbilityRunning = true
    -- Build boards for everyone already in
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Plr and p.Character then PremBuildBB(p) end
    end
    -- Single shared polling loop — much cheaper than per-player loops
    task.spawn(function()
        while PremAbilityRunning do
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Plr then
                    PremRefreshBB(p)
                end
            end
            -- Prune players who left
            for p, entry in pairs(PremAbilityBBs) do
                if not p.Parent then
                    pcall(function() if entry.bb and entry.bb.Parent then entry.bb:Destroy() end end)
                    PremAbilityBBs[p] = nil
                end
            end
            task.wait(0.6)  -- lighter interval than free's 0.4
        end
    end)
    -- Hook new players / respawns
    Players.PlayerAdded:Connect(function(p)
        if not PremAbilityRunning then return end
        p.CharacterAdded:Connect(function()
            task.wait(0.4)
            if PremAbilityRunning then PremBuildBB(p) end
        end)
    end)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Plr then
            p.CharacterAdded:Connect(function()
                task.wait(0.4)
                if PremAbilityRunning then PremBuildBB(p) end
            end)
        end
    end
end

local function StopPremAbilityESP()
    PremAbilityRunning = false
    for _, entry in pairs(PremAbilityBBs) do
        pcall(function() if entry.bb and entry.bb.Parent then entry.bb:Destroy() end end)
    end
    PremAbilityBBs = {}
end

