            {Color=Color3.fromRGB(255,255,255), Thickness=3}):Play()
        task.wait(0.15)
        TweenService:Create(CardStroke, TweenInfo.new(0.4),
            {Color=Color3.fromRGB(0,210,255), Thickness=1.8}):Play()

        -- ── SCAN LINE FLICKER THEN FADE ───────────────────────────
        task.wait(0.6)
        scanRunning = false
        TweenService:Create(ScanContainer, TweenInfo.new(0.3),
            {BackgroundTransparency=1}):Play()
        for _, line in ipairs(scanLines) do
            TweenService:Create(line, TweenInfo.new(0.3),
                {BackgroundTransparency=1}):Play()
        end
        TweenService:Create(GridContainer, TweenInfo.new(0.4),
            {BackgroundTransparency=1}):Play()

        task.wait(1.2)

        -- ── FADE OUT ──────────────────────────────────────────────
        local ft = TweenInfo.new(0.35)
        TweenService:Create(BG,    ft, {BackgroundTransparency=1}):Play()
        TweenService:Create(Card,  ft, {BackgroundTransparency=1}):Play()
        TweenService:Create(CardStroke, ft, {Transparency=1}):Play()
        TweenService:Create(Headline, ft, {TextTransparency=1}):Play()
        TweenService:Create(SubLbl,   ft, {TextTransparency=1}):Play()
        TweenService:Create(IconLbl,  ft, {TextTransparency=1}):Play()
        TweenService:Create(Badge,    ft, {TextTransparency=1}):Play()
        TweenService:Create(Accent, ft, {BackgroundTransparency=1}):Play()
        TweenService:Create(CDivider, ft, {BackgroundTransparency=1}):Play()

        task.wait(0.4)
        pcall(function() AnimSG:Destroy() end)
    end)
end

