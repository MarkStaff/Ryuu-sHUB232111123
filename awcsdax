local function StartAbilityESP()
    CleanAbilityESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Plr then
            BuildAbilityBB(p)
            RefreshBB(p)
        end
    end
    task.spawn(function()
        while S.AbilityESP do
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Plr then
                    if p.Character then
                        local head = p.Character:FindFirstChild("Head")
                        if head then
                            local bb = AbilityBBs[p]
                            if not bb or not bb.Parent or bb.Parent ~= head then
                                BuildAbilityBB(p)
                            end
                            RefreshBB(p)
                        end
                    end
                end
            end
            for p, bb in pairs(AbilityBBs) do
                if not p.Parent then
                    pcall(function() if bb and bb.Parent then bb:Destroy() end end)
                    AbilityBBs[p] = nil
