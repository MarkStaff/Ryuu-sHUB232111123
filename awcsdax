            CloseBtn.TextColor3=Color3.fromRGB(160,160,200); CloseBtn.ZIndex=15

            local function closeScanner()
                rainActive=false; scanActive=false
                TweenService:Create(Overlay,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play()
                TweenService:Create(Card2,TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0),Position=UDim2.new(0.5,0,1.3,0)}):Play()
                TweenService:Create(OrbContainer,TweenInfo.new(0.4),{Size=UDim2.new(0,0,0,0)}):Play()
                task.wait(0.45); pcall(function() KSG:Destroy() end)
            end
            CloseBtn.MouseButton1Click:Connect(closeScanner)

            -- Animated entrance for card
            TweenService:Create(Card2,TweenInfo.new(0.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,460,0,228)}):Play()
            playSound(4590662766,0.55,1.1)

            -- Animated accent gradient rotation
            task.spawn(function()
                local rot=0
                while Card2.Parent and scanActive do
                    rot=(rot+1.5)%360; pcall(function() AccentGrad.Rotation=rot; HGrad.Rotation=rot*0.3 end); task.wait(0.016)
                end
            end)

            -- ── VERIFICATION LOGIC ─────────────────────────────────
            local function doVerify()
                local key=HiddenInput.Text:match("^%s*(.-)%s*$") or ""
                if #key<6 then
                    Status.Text="◈  Key too short — try again"
                    Status.TextColor3=Color3.fromRGB(255,140,40)
                    playSound(6042053626,0.5,0.75)
                    return
                end

                HiddenInput.TextEditable=false; VerifyBtn.Active=false
                Status.Text="◈  SCANNING  —  authenticating..."; Status.TextColor3=Color3.fromRGB(0,200,255)

