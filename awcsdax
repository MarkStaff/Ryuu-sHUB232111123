    if not TrajSG.Parent then pcall(function() TrajSG.Parent=Plr:WaitForChild("PlayerGui") end) end

    -- Neon line (solid) from ball position to predicted impact
    local Line = Instance.new("Frame", TrajSG)
    Line.BackgroundColor3 = Color3.fromRGB(255,60,60)
    Line.BorderSizePixel = 0; Line.ZIndex = 5; Line.Visible = false
    Instance.new("UICorner",Line).CornerRadius = UDim.new(1,0)
    -- Glow behind line
    local LineGlow = Instance.new("Frame", TrajSG)
    LineGlow.BackgroundColor3 = Color3.fromRGB(255,80,80)
    LineGlow.BackgroundTransparency = 0.7; LineGlow.BorderSizePixel = 0; LineGlow.ZIndex = 4; LineGlow.Visible = false
    Instance.new("UICorner",LineGlow).CornerRadius = UDim.new(1,0)
    -- Arrow tip triangle (just a rotated frame)
    local Arrow = Instance.new("Frame", TrajSG)
    Arrow.AnchorPoint = Vector2.new(0.5,0.5)
    Arrow.Size = UDim2.new(0,10,0,10); Arrow.BorderSizePixel = 0
    Arrow.BackgroundColor3 = Color3.fromRGB(255,60,60); Arrow.ZIndex = 6; Arrow.Visible = false
    Instance.new("UICorner",Arrow).CornerRadius = UDim.new(0,2)

    TrajConnActive = true
    RunService.Heartbeat:Connect(function()
        if not PF.TrajectoryESP or not PremiumUnlocked then
            Line.Visible = false; LineGlow.Visible = false; Arrow.Visible = false; return
        end
        local ball = GetBall(); if not ball then Line.Visible=false; LineGlow.Visible=false; Arrow.Visible=false; return end
        local hrp = GetHRP(); if not hrp then Line.Visible=false; LineGlow.Visible=false; Arrow.Visible=false; return end
        local vel = GetVel(ball); local spd = vel.Magnitude
        if spd < 2 then Line.Visible=false; LineGlow.Visible=false; Arrow.Visible=false; return end

        local isTgt = (ball:GetAttribute("target") or "") == Plr.Name
        local ahead = ball.Position + vel.Unit * math.min(spd * 0.5, 50)
        local sp1, on1 = Cam:WorldToViewportPoint(ball.Position)
        local sp2, on2 = Cam:WorldToViewportPoint(ahead)
        if not on1 then Line.Visible=false; LineGlow.Visible=false; Arrow.Visible=false; return end

        local dx = sp2.X - sp1.X; local dy = sp2.Y - sp1.Y
        local len = math.sqrt(dx*dx + dy*dy)
        if len < 3 then return end
        local rot = math.deg(math.atan2(dy, dx))
        local col = isTgt and Color3.fromRGB(255,50,50) or Color3.fromRGB(0,200,255)
        local glowCol = isTgt and Color3.fromRGB(255,100,100) or Color3.fromRGB(60,210,255)

        pcall(function()
            Line.Visible=true; Line.BackgroundColor3=col
            Line.Size=UDim2.new(0,len,0,2)
            Line.Position=UDim2.new(0,sp1.X,0,sp1.Y-1)
            Line.Rotation=rot
            LineGlow.Visible=true; LineGlow.BackgroundColor3=glowCol
            LineGlow.Size=UDim2.new(0,len,0,6)
            LineGlow.Position=UDim2.new(0,sp1.X,0,sp1.Y-3)
            LineGlow.Rotation=rot
            -- Arrow tip at end point
            Arrow.Visible=true; Arrow.BackgroundColor3=col
            Arrow.Position=UDim2.new(0,sp2.X,0,sp2.Y)
            Arrow.Rotation=rot+45
        end)
    end)
end

