local function RunDetector(sigList, fireFn, pollRate)
    local conn
    conn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local ball = GetBall(); if not ball then return end
            local tgt  = ball:GetAttribute("target"); if not tgt then return end
            -- Only care about enemies who currently have the ball targeting them
            -- AND who are not us (we only parry when they redirect back at us,
            -- but ability detects should fire when ball is heading to us from them)
            -- Actually: fire when the ball is targeting US — enemy already sent it
            -- OR when enemy has ability active and ball is near them about to redirect
            local myHRP = GetHRP(); if not myHRP then return end

            for _, p in ipairs(Players:GetPlayers()) do
                if p == Plr then continue end
                local char = p.Character; if not char then continue end
                local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then continue end
                local distToMe = (myHRP.Position - hrp.Position).Magnitude
                if distToMe > 100 then continue end  -- too far, skip

                -- Check if this enemy currently holds the ball (it's targeting them)
                -- OR the ball was recently redirected by them at us
                local ballNearEnemy = (hrp.Position - ball.Position).Magnitude < 20
                local ballTargetsMe = tgt == Plr.Name

                if not (ballNearEnemy or ballTargetsMe) then continue end

                local now = os.clock()
                local cdKey = p.Name
                if Det.cds[cdKey] and now - Det.cds[cdKey] < Det.cd then continue end

                -- Run ability signatures
                for _, sig in ipairs(sigList) do
                    if sig.check(char, p) then
                        -- Ability detected — fire parry NOW
                        Det.cds[cdKey] = now
                        task.spawn(function()
                            fireFn()
                            Rayfield:Notify({
                                Title = "⚡ ABILITY DETECTED",
                                Content = sig.name .. " — parry fired!",
                                Duration = 1.2,
                                Image = 4483362458,
                            })
                        end)
                        break
                    end
                end
            end
        end)
    end)
    return conn
end

