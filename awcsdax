    if SBH.conn then SBH.conn:Disconnect() end
    SBH.conn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local ball = GetBall(); if not ball then return end
            local bp = ball:FindFirstChildOfClass("BasePart") or ball
            if not bp:IsA("BasePart") then return end
            if ball:GetAttribute("target") == Plr.Name then
                if SBH.color == nil then
                    SBH.color = bp.Color
                    SBH.mat   = bp.Material
                end
                bp.Color    = Color3.fromRGB(255, 50, 50)
                bp.Material = Enum.Material.Neon
            else
                if SBH.color then
                    bp.Color    = SBH.color
                    bp.Material = SBH.mat
                    SBH.color = nil; SBH.mat = nil
                end
            end
        end)
    end)
end
