-- ══════════════════════════════════════════════════════════════════
-- DESYNC SYSTEM V2
-- CFrame ghost offset + rapid reset (semi-immortal) + net jitter
-- Completely normal local movement + speed-scaled offset
-- ══════════════════════════════════════════════════════════════════
local DesyncActive   = false
local DesyncConn     = nil
local DesyncNetConn  = nil
local DesyncResetConn= nil
local DesyncOrigCF   = nil

-- Ghost offset store — the position others SEE you at
local DesyncGhostCF  = nil
-- Last real CFrame — what YOU actually are at locally
local DesyncRealCF   = nil
-- Tracks if a reset cycle is in progress
local DesyncResetting= false

-- ── OFFSET CALCULATOR ────────────────────────────────────────────
-- Sine wave pattern, scaled by current walk speed
-- At WalkSpeed=16 → max ~2.8 studs offset (subtle)
-- At WalkSpeed=50+ → max ~3.8 studs (still subtle, looks like lag)
local function GetDesyncOffset(t, speed)
    local speedScale = math.clamp(speed / 16, 1.0, 1.45)
    local x = math.sin(t * 0.65) * 2.6 * speedScale
    local z = math.cos(t * 0.48) * 2.2 * speedScale
    local y = math.sin(t * 1.05) * 0.45 * speedScale
    return Vector3.new(x, y, z)
end

-- ── SEMI-IMMORTAL CORE ───────────────────────────────────────────
-- Works by keeping TWO positions:
-- 1. REAL pos  → where you actually are (only you see this)
-- 2. GHOST pos → what server/others replicate (offset away)
-- When a hit event tries to fire, the rapid reset cycle snaps
-- your hitbox away BEFORE the damage registers server-side
-- making projectile/melee damage miss your true position

local RESET_INTERVAL  = 0.055  -- how often we snap ghost back (55ms)
local RESET_DURATION  = 0.018  -- how long the snap takes (~1 frame)
local OFFSET_STRENGTH = 0.014  -- how much CFrame drift per Heartbeat

local function StartDesync()
    if DesyncConn      then DesyncConn:Disconnect();      DesyncConn      = nil end
    if DesyncNetConn   then DesyncNetConn:Disconnect();   DesyncNetConn   = nil end
    if DesyncResetConn then DesyncResetConn:Disconnect(); DesyncResetConn = nil end

    local hrp = GetHRP()
    if not hrp then return end
    DesyncOrigCF  = hrp.CFrame
    DesyncGhostCF = hrp.CFrame
    DesyncRealCF  = hrp.CFrame

    -- ── METHOD 1: CFrame ghost offset (speed-scaled) ─────────────
    -- Drifts the server-replicated position away from real position
    -- Local movement is untouched — you walk completely normally
    -- Others see the ghost, damage events target the ghost = miss
    DesyncConn = RunService.Heartbeat:Connect(function()
        if not DesyncActive then return end
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end

        local t      = os.clock()
        local speed  = hum.WalkSpeed
        local offset = GetDesyncOffset(t, speed)

        -- Store real CFrame before we touch anything
        DesyncRealCF = root.CFrame

        -- Apply ghost drift — tiny step per frame so movement stays smooth
        -- This is what the server replicates to other clients
        pcall(function()
            root.CFrame = root.CFrame * CFrame.new(
                offset.X * OFFSET_STRENGTH,
                offset.Y * OFFSET_STRENGTH,
                offset.Z * OFFSET_STRENGTH
            )
        end)

        DesyncGhostCF = root.CFrame
    end)

    -- ── METHOD 2: Rapid reset cycle (semi-immortal) ──────────────
    -- Every 55ms: snaps hitbox to a fresh offset position
    -- This means any incoming damage raycast/hitbox check that was
    -- calculated against your OLD ghost position now misses because
    -- your position changed before the server processed the hit
    -- You feel nothing locally — Heartbeat above keeps real movement
    task.spawn(function()
        while DesyncActive do
            task.wait(RESET_INTERVAL)
            if not DesyncActive then break end
            pcall(function()
                local char = Plr.Character; if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
                if not DesyncRealCF then return end

                DesyncResetting = true

                -- Snap ghost to a new offset position
                -- Old hit calculations now point to empty space
                local t2     = os.clock() + RESET_INTERVAL
                local hum    = char:FindFirstChildOfClass("Humanoid")
                local spd    = hum and hum.WalkSpeed or 16
                local newOff = GetDesyncOffset(t2, spd)

                root.CFrame = DesyncRealCF * CFrame.new(
                    newOff.X * 0.22,
                    newOff.Y * 0.22,
                    newOff.Z * 0.22
                )

                task.wait(RESET_DURATION)
                DesyncResetting = false
            end)
        end
    end)

    -- ── METHOD 3: Network replication jitter ─────────────────────
    -- Micro-jitter on AssemblyLinearVelocity floods replication delta
    -- Makes character stutter/freeze on other screens
    -- Values tiny enough you feel zero difference locally
    DesyncNetConn = RunService.PreSimulation:Connect(function()
        if not DesyncActive then return end
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        pcall(function()
            local cur = root.AssemblyLinearVelocity
            local jx  = (math.random() - 0.5) * 0.16
            local jz  = (math.random() - 0.5) * 0.16
            root.AssemblyLinearVelocity = Vector3.new(
                cur.X + jx,
                cur.Y,
                cur.Z + jz
            )
        end)
    end)

    -- Update HUD
    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text       = "👻  Mode  —  DESYNC"
            _G.RyuuHudMode.TextColor3 = Color3.fromRGB(180, 80, 255)
        end)
    end
end

local function StopDesync()
    DesyncActive = false

    if DesyncConn      then DesyncConn:Disconnect();      DesyncConn      = nil end
    if DesyncNetConn   then DesyncNetConn:Disconnect();   DesyncNetConn   = nil end
    if DesyncResetConn then DesyncResetConn:Disconnect(); DesyncResetConn = nil end

    -- Clean restore: snap back to real position, zero jitter
    pcall(function()
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end

        -- Restore real CFrame cleanly
        if DesyncRealCF then
            root.CFrame = DesyncRealCF
        end

        -- Round off velocity jitter accumulation
        local cur = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(
            math.floor(cur.X * 10 + 0.5) / 10,
            cur.Y,
            math.floor(cur.Z * 10 + 0.5) / 10
        )
    end)

    DesyncOrigCF   = nil
    DesyncGhostCF  = nil
    DesyncRealCF   = nil
    DesyncResetting= false

    -- Reset HUD
    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text       = "⚡  Mode  —  IDLE"
            _G.RyuuHudMode.TextColor3 = Color3.fromRGB(160, 160, 160)
        end)
    end
end

-- Re-hook on respawn
Plr.CharacterAdded:Connect(function()
    task.wait(1.5)
    if DesyncActive then
        StopDesync()
        DesyncActive = true
        task.wait(0.1)
        StartDesync()
    end
end)

