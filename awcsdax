-- FREE PARRY ENGINE (Upgraded)

local FREE_PING_LEAD = 0.9
local FREE_HITBOX = 6.2

local PrevVel = nil

local function StartEngine()

    if Conn.Parry then
        Conn.Parry:Disconnect()
    end

    BuildParryIndicator()

    Conn.Parry = RunService.PreSimulation:Connect(function()

        if not S.AutoParry then return end

        local Ball = GetBall()
        if not Ball then return end

        local HRP = GetHRP()
        if not HRP then return end

        local BPos = Ball.Position
        local HPos = HRP.Position

        local Dist = (HPos - BPos).Magnitude

        local tgt = Ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if not isTgt then
            UpdateParryIndicator(99,1,false)
            return
        end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        local toPlayer = HPos - BPos
        local dotVal = Vel:Dot(toPlayer)

        -- allow slight sideways movement
        local isClosing = dotVal > -(Speed * 0.25)

        -- dynamic hitbox
        local dynamicHitbox =
            FREE_HITBOX +
            math.clamp(Speed / 180,0,1) * 2

        local pingLead =
            (PingRaw / 1000) *
            Speed *
            FREE_PING_LEAD

        pingLead = math.min(pingLead,3)

        local fireDist = dynamicHitbox + pingLead

        UpdateParryIndicator(Dist,fireDist,false)

        if isClosing and Dist <= fireDist then
            FireParry(Ball)
            UpdateParryIndicator(Dist,fireDist,true)
            return
        end

        -- basic lookahead
        if Speed > 80 then

            local dt = 1/60

            for step=1,2 do

                local nextPos = BPos + Vel*(dt*step)

                if (HPos-nextPos).Magnitude <= fireDist then

                    FireParry(Ball)
                    UpdateParryIndicator(Dist,fireDist,true)
                    return
                end
            end
        end

        PrevVel = Vel

    end)
end

