    Heading.TextTransparency = 1
    Heading.ZIndex = 5
    local HGrad = Instance.new("UIGradient", Heading)
    HGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(200,120,255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,255,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200,120,255)),
    }
    TweenService:Create(Heading, TweenInfo.new(0.3), {TextTransparency = 0}):Play()

    -- Sub text
    local Sub = Instance.new("TextLabel", Card)
    Sub.Size = UDim2.new(1,-20,0,20)
    Sub.Position = UDim2.new(0,10,0,104)
    Sub.BackgroundTransparency = 1
    Sub.Text = "All premium features are now active"
    Sub.Font = Enum.Font.Gotham
    Sub.TextSize = 13
    Sub.TextColor3 = Color3.fromRGB(180,130,255)
    Sub.TextTransparency = 1
    Sub.ZIndex = 5
    TweenService:Create(Sub, TweenInfo.new(0.3), {TextTransparency = 0}):Play()

    -- Divider line
    local DivL = Instance.new("Frame", Card)
    DivL.Size = UDim2.new(0.65,0,0,1)
    DivL.Position = UDim2.new(0.175,0,0,130)
    DivL.BackgroundColor3 = Color3.fromRGB(100,40,200)
    DivL.BorderSizePixel = 0
    DivL.ZIndex = 5

    -- Version tag
    local Tag = Instance.new("TextLabel", Card)
    Tag.Size = UDim2.new(1,0,0,22)
