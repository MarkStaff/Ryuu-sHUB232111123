-- DESYNC SYSTEM V2  (single declaration — duplicate removed)
-- ══════════════════════════════════════════════════════════════════
local DS = {
    active    = false,
    conn      = nil,
    netConn   = nil,
    resetConn = nil,
    origCF    = nil,
    ghostCF   = nil,
    realCF    = nil,
    resetting = false,
}

local RESET_INTERVAL  = 0.055
local RESET_DURATION  = 0.018
local OFFSET_STRENGTH = 0.014

local function GetDesyncOffset(t, speed)
    local speedScale = math.clamp(speed / 16, 1.0, 1.45)
    local x = math.sin(t * 0.65) * 2.6 * speedScale
    local z = math.cos(t * 0.48) * 2.2 * speedScale
    local y = math.sin(t * 1.05) * 0.45 * speedScale
    return Vector3.new(x, y, z)
end

local function StartDesync()
    if DS.conn      then DS.conn:Disconnect();      DS.conn      = nil end
    if DS.netConn   then DS.netConn:Disconnect();   DS.netConn   = nil end
    if DS.resetConn then DS.resetConn:Disconnect(); DS.resetConn = nil end

    local hrp = GetHRP()
    if not hrp then return end
    DS.origCF  = hrp.CFrame
    DS.ghostCF = hrp.CFrame
    DS.realCF  = hrp.CFrame

    DS.conn = RunService.Heartbeat:Connect(function()
        if not DS.active then return end
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end

        local t      = os.clock()
        local speed  = hum.WalkSpeed
        local offset = GetDesyncOffset(t, speed)

        DS.realCF = root.CFrame

        pcall(function()
            root.CFrame = root.CFrame * CFrame.new(
                offset.X * OFFSET_STRENGTH,
                offset.Y * OFFSET_STRENGTH,
                offset.Z * OFFSET_STRENGTH
            )
        end)

        DS.ghostCF = root.CFrame
    end)

    task.spawn(function()
        while DS.active do
            task.wait(RESET_INTERVAL)
            if not DS.active then break end
            pcall(function()
                local char = Plr.Character; if not char then return end
                local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
                if not DS.realCF then return end

                DS.resetting = true

                local t2     = os.clock() + RESET_INTERVAL
                local hum    = char:FindFirstChildOfClass("Humanoid")
                local spd    = hum and hum.WalkSpeed or 16
                local newOff = GetDesyncOffset(t2, spd)

                root.CFrame = DS.realCF * CFrame.new(
                    newOff.X * 0.22,
                    newOff.Y * 0.22,
                    newOff.Z * 0.22
                )

                task.wait(RESET_DURATION)
                DS.resetting = false
            end)
        end
    end)

    DS.netConn = RunService.PreSimulation:Connect(function()
        if not DS.active then return end
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end
        pcall(function()
            local cur = root.AssemblyLinearVelocity
            local jx  = (math.random() - 0.5) * 0.16
            local jz  = (math.random() - 0.5) * 0.16
            root.AssemblyLinearVelocity = Vector3.new(cur.X + jx, cur.Y, cur.Z + jz)
        end)
    end)

    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text       = "👻  Mode  —  DESYNC"
            _G.RyuuHudMode.TextColor3 = Color3.fromRGB(180, 80, 255)
        end)
    end
end

local function StopDesync()
    DS.active = false

    if DS.conn      then DS.conn:Disconnect();      DS.conn      = nil end
    if DS.netConn   then DS.netConn:Disconnect();   DS.netConn   = nil end
    if DS.resetConn then DS.resetConn:Disconnect(); DS.resetConn = nil end

    pcall(function()
        local char = Plr.Character; if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart"); if not root then return end

        if DS.realCF then root.CFrame = DS.realCF end

        local cur = root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity = Vector3.new(
            math.floor(cur.X * 10 + 0.5) / 10,
            cur.Y,
            math.floor(cur.Z * 10 + 0.5) / 10
        )
    end)

    DS.origCF    = nil
    DS.ghostCF   = nil
    DS.realCF    = nil
    DS.resetting = false

    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text       = "⚡  Mode  —  IDLE"
            _G.RyuuHudMode.TextColor3 = Color3.fromRGB(160, 160, 160)
        end)
    end
end

Plr.CharacterAdded:Connect(function()
    task.wait(1.5)
    if DS.active then
        StopDesync()
        DS.active = true
        task.wait(0.1)
        StartDesync()
    end
end)

