local FPS_Active=false; local FPS_Saved={effects={},casters={},fidelity={}}
local FPS_Label_Ref=nil
local function ApplyFPS(level)
    if FPS_Active then return end; FPS_Active=true
    FPS_Saved.tech=Lighting.Technology; FPS_Saved.shadow=Lighting.GlobalShadows
    FPS_Saved.envD=Lighting.EnvironmentDiffuseScale; FPS_Saved.envS=Lighting.EnvironmentSpecularScale
    pcall(function()
        local tech={Enum.Technology.ShadowMap,Enum.Technology.Voxel,Enum.Technology.Compatibility}
        Lighting.Technology=tech[level] or tech[2]
    end)
    if level>=2 then Lighting.GlobalShadows=false;Lighting.EnvironmentDiffuseScale=0;Lighting.EnvironmentSpecularScale=0 end
    FPS_Saved.effects={}
    for _,e in ipairs(Lighting:GetChildren()) do
        if e:IsA("PostEffect") then table.insert(FPS_Saved.effects,{o=e,was=e.Enabled})
            if level>=2 then pcall(function() e.Enabled=false end) end
        end
    end
    if level>=2 then
        FPS_Saved.casters={}; FPS_Saved.fidelity={}
        pcall(function()
            for _,v in ipairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") then
                    if v.CastShadow then table.insert(FPS_Saved.casters,v); v.CastShadow=false end
                    if v.RenderFidelity~=Enum.RenderFidelity.Performance then
                        table.insert(FPS_Saved.fidelity,{o=v,was=v.RenderFidelity})
                        pcall(function() v.RenderFidelity=Enum.RenderFidelity.Performance end)
                    end
                end
            end
        end)
        if Conn.FPSWatch then Conn.FPSWatch:Disconnect() end
        Conn.FPSWatch=workspace.DescendantAdded:Connect(function(v)
            if not FPS_Active then return end
            if v:IsA("BasePart") then pcall(function() v.CastShadow=false;v.RenderFidelity=Enum.RenderFidelity.Performance end) end
        end)
    end
end
local function RemoveFPS()
    if not FPS_Active then return end; FPS_Active=false
    if Conn.FPSWatch then Conn.FPSWatch:Disconnect();Conn.FPSWatch=nil end
    pcall(function() Lighting.Technology=FPS_Saved.tech end)
    pcall(function() Lighting.GlobalShadows=FPS_Saved.shadow end)
    pcall(function() Lighting.EnvironmentDiffuseScale=FPS_Saved.envD end)
    pcall(function() Lighting.EnvironmentSpecularScale=FPS_Saved.envS end)
    for _,e in ipairs(FPS_Saved.effects) do pcall(function() e.o.Enabled=e.was end) end
    for _,v in ipairs(FPS_Saved.casters) do pcall(function() v.CastShadow=true end) end
    for _,e in ipairs(FPS_Saved.fidelity) do pcall(function() e.o.RenderFidelity=e.was end) end
end
