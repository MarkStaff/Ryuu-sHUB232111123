-- PREMIUM ENGINE ◈ FULLY UPGRADED
-- ══════════════════════════════════════════════════════════════════
-- Includes all free fixes PLUS premium-exclusive upgrades:
-- FREE FIXES APPLIED:
--   • Emergency only fires when ball targets YOU (no random pre-clicks)
--   • Full ping compensation: PingMs/1000 (was /2000)
--   • Hitbox 7.5 studs (free=6.5, old premium=4.0 which was too tight)
--   • AntiCurve threshold sc>1.5 (free=2, old=5 — premium catches gentler curves)
--   • DidParry reset fixed to 0.12s (not tied to slider)
--   • History expanded to 8 frames (free=5)
--   • Direction reversal threshold -0.25 (free=-0.3, tighter for premium)
-- PREMIUM EXCLUSIVE UPGRADES:
--   • 3-frame lookahead extrapolation (free=2 frames)
--   • Weighted closing speed: recent frames count more than old ones
--   • Dual prediction: both linear + quadratic, fires on whichever triggers first
--   • Adaptive ping: uses min of last 3 ping samples for tightest compensation
--   • God Emergency: only fires when YOU are target (same fix as free + tighter dist)
--   • Speed burst detection: 3-frame window, 1.18x adjust (free=1.15x)
-- ══════════════════════════════════════════════════════════════════
local PremiumConn = {}
local P = {
    AutoParry = false,
    GodEmergency = false,
    CurveCrusher = false,
    AutoFace = false,
    HitboxTarget = 12.0,    -- wider than free's 6.5 — catches everything
    SpeedBoostDetect = true,
    QuadCurvePredict = true,
}

-- 8-frame position history for quadratic prediction
local speedHist = {}
local posHistQuad = {}
local function pushQuadHist(pos, t)
    table.insert(posHistQuad, {p=pos, t=t})
    if #posHistQuad > 8 then table.remove(posHistQuad, 1) end
end

-- Quadratic position prediction using acceleration estimate
local function predictQuadPos(curPos, curVel, dt)
    if #posHistQuad < 3 then return curPos + curVel * dt end
    local p1, p2, p3 = posHistQuad[1].p, posHistQuad[2].p, posHistQuad[3].p
    local v1 = p2 - p1
    local v2 = p3 - p2
    local accel = v2 - v1
    return curPos + curVel * dt + 0.5 * accel * dt^2
end

-- 8-frame closing speed history with weighted average (recent = more weight)
local posHist = {}
local MAX_HIST = 8
local function pushHist(dist, t)
    table.insert(posHist, {d=dist, t=t})
    if #posHist > MAX_HIST then table.remove(posHist, 1) end
end
local function smoothClosing(curDist, curTime)
    if #posHist < 2 then return 0 end
    -- Weighted: compare current vs oldest for base, then weight by recency
    local oldest = posHist[1]
    local dt = curTime - oldest.t
    if dt <= 0 then return 0 end
    local base = (oldest.d - curDist) / dt
    -- Also check last 2 frames for recent acceleration
    if #posHist >= 3 then
        local recent = posHist[#posHist - 1]
        local rdt = curTime - recent.t
        if rdt > 0 then
            local recentClosing = (recent.d - curDist) / rdt
            -- Weight recent closing 60%, overall 40%
            return recentClosing * 0.6 + base * 0.4
        end
    end
    return base
end

-- Adaptive ping: use min of last 3 samples for best-case compensation
local PingAdapt = {min=60, samples={}}
task.spawn(function()
    while true do
        task.wait(1.5)
        table.insert(PingAdapt.samples, PingMs)
        if #PingAdapt.samples > 3 then table.remove(PingAdapt.samples, 1) end
        local min = PingMs
        for _, v in ipairs(PingAdapt.samples) do if v < min then min = v end end
        PingAdapt.min = min
    end
end)

S.PremReset = 0.12

local function PremiumFire()
    if S.DidParry then return end
    if os.clock() - S.LastParry < 0.12 then return end
    VIM:SendMouseButtonEvent(0,0,0,true, game, 0)
    S.LastParry = os.clock()
