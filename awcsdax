local PingMs = 60
local PingBonus = 0
local PingScale = 1.0
local PingSamples = {}
task.spawn(function()
    while true do
        local ok, raw = pcall(function()
            return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        if ok and type(raw)=="number" and raw > 0 then
            table.insert(PingSamples, raw)
            if #PingSamples > 6 then table.remove(PingSamples, 1) end
            local sum = 0
            for _, v in ipairs(PingSamples) do sum = sum + v end
            PingMs = sum / #PingSamples
            PingBonus = (PingMs/1000) * PingScale
        end
        task.wait(2)
    end
end)
