-- BALL / PLAYER HELPERS
-- ══════════════════════════════════════════════════════════════════
local function GetBall()
    local folder = workspace:FindFirstChild("Balls")
    if folder then
        for _,v in ipairs(folder:GetChildren()) do
            if v:IsA("BasePart") and v:GetAttribute("realBall") then return v end
        end
        for _,v in ipairs(folder:GetChildren()) do
            if v:IsA("BasePart") then return v end
        end
    end
    for _,v in ipairs(workspace:GetChildren()) do
        if v:IsA("BasePart") and v.Name:lower():find("ball") then return v end
    end
    return nil
end

local function GetHRP()
    local c=Plr.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function GetVel(ball)
    local best = Vector3.zero
    local ok1,v1 = pcall(function() return ball.AssemblyLinearVelocity end)
    if ok1 and v1.Magnitude>best.Magnitude then best=v1 end
    pcall(function()
        for _,d in ipairs(ball:GetChildren()) do
            if (d:IsA("BodyVelocity") or d:IsA("LinearVelocity"))
                and d.VectorVelocity.Magnitude>best.Magnitude then
                best=d.VectorVelocity
            end
        end
    end)
    return best
end

-- ══════════════════════════════════════════════════════════════════
-- PING SAMPLER
--   PingMs  = lowest sample in window  → used for parry compensation
--   PingRaw = exact latest reading     → shown on HUD (real ms)
-- ══════════════════════════════════════════════════════════════════
local PingMs      = 1    -- lowest (for parry math)
local PingRaw     = 0    -- real current ms (for HUD display)
local PingBonus   = 0
local PingScale   = 1.0
local PingSamples = {}
local PingJitter  = 0

task.spawn(function()
    while true do
        local ok, raw = pcall(function()
            return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        if ok and type(raw)=="number" and raw>0 then
            PingRaw = raw  -- always store the unmodified reading for HUD

            table.insert(PingSamples, raw)
            if #PingSamples>12 then table.remove(PingSamples,1) end

            -- PingMs = lowest sample in window (keeps parry compensation tight)
            local lowest = math.huge
            for _,v in ipairs(PingSamples) do
                if v < lowest then lowest = v end
            end
            PingMs = lowest

            -- Jitter = mean absolute deviation of last 4 samples
            if #PingSamples>=4 then
                local n = #PingSamples
                local recent = {PingSamples[n], PingSamples[n-1], PingSamples[n-2], PingSamples[n-3]}
                local jSum=0; for _,v in ipairs(recent) do jSum=jSum+v end
                local jMean=jSum/4
                local jDev=0; for _,v in ipairs(recent) do jDev=jDev+math.abs(v-jMean) end
                PingJitter = jDev/4
            end

            -- PingBonus uses lowest ping for fastest possible compensation
            PingBonus = (PingMs/1000) * PingScale
        end
        task.wait(0.5)
    end
end)

local PingLabel = nil
task.spawn(function()
