            -- Divider
            local CDivider2=Instance.new("Frame",Card2); CDivider2.Size=UDim2.new(1,-64,0,1); CDivider2.Position=UDim2.new(0,32,0,66)
            CDivider2.BackgroundColor3=Color3.fromRGB(0,140,200); CDivider2.BorderSizePixel=0; CDivider2.ZIndex=13

            -- ── HOLOGRAPHIC KEY INPUT FIELD ────────────────────────
            -- Instead of one big textbox, we have:
            -- 1. A holographic slot bar showing filled / empty cells
            -- 2. A hidden TextBox behind it that captures actual input
            -- 3. Real-time red → green color shift as chars are typed
            -- 4. Glowing cursor frame

            local InputLabel=Instance.new("TextLabel",Card2); InputLabel.Size=UDim2.new(1,-64,0,14); InputLabel.Position=UDim2.new(0,32,0,76)
            InputLabel.BackgroundTransparency=1; InputLabel.Text="▸ AUTHORIZATION KEY"; InputLabel.Font=Enum.Font.GothamBlack; InputLabel.TextSize=9
            InputLabel.TextColor3=Color3.fromRGB(0,160,200); InputLabel.TextXAlignment=Enum.TextXAlignment.Left; InputLabel.ZIndex=14

            -- Slot display container (visual only)
            local SlotContainer=Instance.new("Frame",Card2); SlotContainer.Size=UDim2.new(1,-64,0,36); SlotContainer.Position=UDim2.new(0,32,0,92)
            SlotContainer.BackgroundColor3=Color3.fromRGB(5,14,26); SlotContainer.BackgroundTransparency=0.1; SlotContainer.BorderSizePixel=0; SlotContainer.ZIndex=14
