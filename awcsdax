-- ══════════════════════════════════════════════════════════════════
-- ██████  GHOST DESYNC — UPGRADED
-- Invisible to the server. Your hitbox drifts just enough that
-- the server can never reliably confirm the ball hit you.
--
-- HOW IT WORKS (3 layers, all subtle):
--   1. Micro-jitter  — tiny random XZ position flicks each frame
--                      (< 0.4 studs, invisible to other players)
--   2. Phase drift   — slow sinusoidal offset synced to a secret
--                      phase so it looks like normal latency
--   3. Net jitter    — small velocity noise injected PreSimulation
--                      so the server's prediction of your position
--                      is always slightly wrong
--
-- What was fixed vs old desync:
--   - NO CFrame teleports → you never get stuck or float
--   - NO position snapping → doesn't cause air spawning
--   - Scales with movement so it's natural-looking
--   - Ball still appears to hit you (client) but server disagrees
--   - Resets cleanly on death / respawn with no side effects
-- ══════════════════════════════════════════════════════════════════
local DS = {
    active    = false,
    mainConn  = nil,
    netConn   = nil,
    -- phase offset so each session looks different
    phase     = math.random() * math.pi * 2,
    -- how aggressive the drift is (0 = off, 1 = max safe)
    strength  = 0.55,
}

-- Cleans up without touching position (safe)
local function StopDesync()
    DS.active = false
    if DS.mainConn then DS.mainConn:Disconnect(); DS.mainConn=nil end
    if DS.netConn  then DS.netConn:Disconnect();  DS.netConn=nil  end

    -- Snap velocity back to clean values so physics doesn't stutter
    pcall(function()
        local char=Plr.Character; if not char then return end
        local root=char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local v=root.AssemblyLinearVelocity
        root.AssemblyLinearVelocity=Vector3.new(
            math.floor(v.X*10+0.5)/10, v.Y, math.floor(v.Z*10+0.5)/10)
    end)

    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text="⚡ Mode — IDLE"
            _G.RyuuHudMode.TextColor3=Color3.fromRGB(160,160,160)
        end)
    end
end

local function StartDesync()
    StopDesync()
    DS.active = true

    -- Layer 1 + 2: position micro-drift (Heartbeat, after physics)
    DS.mainConn = RunService.Heartbeat:Connect(function(dt)
        if not DS.active then return end
        local char=Plr.Character; if not char then return end
        local root=char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end

        -- Don't desync while dead or seated
        if hum.Health<=0 then return end
        if hum.Sit then return end

        local t     = os.clock() + DS.phase
        local str   = DS.strength

        -- Micro-jitter: random each frame, very small
        -- Scales down when standing still (less suspicious)
        local moving = hum.MoveDirection.Magnitude > 0.1
        local jScale = moving and 1.0 or 0.35

        local jx = (math.random()-0.5) * 0.32 * str * jScale
        local jz = (math.random()-0.5) * 0.32 * str * jScale

        -- Phase drift: slow sine wave, looks like interpolation lag
        -- This is what actually desynchronises the hitbox server-side
        local driftX = math.sin(t*0.70+1.3) * 0.55 * str
        local driftZ = math.cos(t*0.53+2.1) * 0.48 * str
        local driftY = math.sin(t*0.90)     * 0.10 * str  -- barely any Y

        -- Apply as a velocity nudge, NOT a teleport
        -- This lets Roblox physics handle the actual movement
        -- so you never get stuck or launched into the air
        pcall(function()
            local cur = root.AssemblyLinearVelocity
            root.AssemblyLinearVelocity = Vector3.new(
                cur.X + (jx + driftX) * 60 * dt,
                cur.Y + driftY        * 30 * dt,
                cur.Z + (jz + driftZ) * 60 * dt
            )
        end)
    end)

    -- Layer 3: network velocity noise (PreSimulation — runs before
    -- the replication snapshot so the server reads the noisy value)
    DS.netConn = RunService.PreSimulation:Connect(function()
        if not DS.active then return end
        local char=Plr.Character; if not char then return end
        local root=char:FindFirstChild("HumanoidRootPart"); if not root then return end
        local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end
        if hum.Health<=0 or hum.Sit then return end

        pcall(function()
            local cur=root.AssemblyLinearVelocity
            -- Tiny net noise — enough to confuse server hit detection
            -- but not enough to visually teleport you
            local nx=(math.random()-0.5)*0.22*DS.strength
            local nz=(math.random()-0.5)*0.22*DS.strength
            root.AssemblyLinearVelocity=Vector3.new(cur.X+nx, cur.Y, cur.Z+nz)
        end)
    end)

    if _G.RyuuHudMode then
        pcall(function()
            _G.RyuuHudMode.Text="👻 Mode — DESYNC"
            _G.RyuuHudMode.TextColor3=Color3.fromRGB(180,80,255)
        end)
    end
end

-- Auto-restart desync after respawn
Plr.CharacterAdded:Connect(function()
    task.wait(2.0)
    if DS.active then
        DS.active=false
        if DS.mainConn then DS.mainConn:Disconnect(); DS.mainConn=nil end
        if DS.netConn  then DS.netConn:Disconnect();  DS.netConn=nil  end
        task.wait(0.5)
        StartDesync()
    end
end)

