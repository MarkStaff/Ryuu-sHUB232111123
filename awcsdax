local function BuildDragon(parent, cx, cy, alpha)
    -- alpha = starting transparency (1 = invisible, 0 = visible)
    local P = Color3.fromRGB(160,60,255)   -- main purple
    local PL = Color3.fromRGB(220,140,255) -- light purple
    local PD = Color3.fromRGB(80,20,160)   -- dark purple
    local W = Color3.fromRGB(240,200,255)  -- near white
    local parts = {}

    local function mk(cls, par, props)
        local o = Instance.new(cls, par)
        for k,v in pairs(props) do o[k]=v end
        return o
    end
    local function fr(par, ax,ay, px,py, sx,sy, rot, col, tr, zi)
        local f = mk("Frame", par, {
            AnchorPoint=Vector2.new(ax,ay),
            Position=UDim2.new(cx+px,0,cy+py,0),
            Size=UDim2.new(sx,0,sy,0),
            BackgroundColor3=col,
            BackgroundTransparency=tr,
            BorderSizePixel=0,
            Rotation=rot,
            ZIndex=zi or 4,
        })
        table.insert(parts, f)
        return f
    end
    local function stroke(f, col, th, tr)
        local s = mk("UIStroke", f, {Color=col,Thickness=th,Transparency=tr or 0})
        return s
    end
    local function corner(f, r)
        mk("UICorner", f, {CornerRadius=UDim.new(r or 0,0)})
    end
    local function grad(f, c0,c1,rot)
        local g = mk("UIGradient", f, {Rotation=rot or 0})
        g.Color = ColorSequence.new{ColorSequenceKeypoint.new(0,c0),ColorSequenceKeypoint.new(1,c1)}
    end

    -- ── BODY (curved S-shape using 3 overlapping ovals) ──────────
    local b1 = fr(parent, 0.5,0.5, -0.02,-.14, 0.07,0.16, -15, PD, alpha,5)
    corner(b1, 0.5); stroke(b1, P, 1.5, alpha)
    grad(b1, PD, P, 90)

    local b2 = fr(parent, 0.5,0.5, 0.00,-.02, 0.06,0.17, 10, PD, alpha,5)
    corner(b2, 0.5); stroke(b2, P, 1.5, alpha)
    grad(b2, PD, P, 90)

    local b3 = fr(parent, 0.5,0.5, -0.01, .10, 0.05,0.14, -8, PD, alpha,5)
    corner(b3, 0.5); stroke(b3, P, 1, alpha)
    grad(b3, PD, P, 90)

    -- ── HEAD ──────────────────────────────────────────────────────
    local head = fr(parent, 0.5,0.5, -0.02,-.26, 0.09,0.075, -10, P, alpha,6)
    corner(head, 0.4); stroke(head, W, 1.5, alpha)
    grad(head, PL, P, 45)

    -- Snout (protruding forward)
    local snout = fr(parent, 0,0.5, 0.025,-.26, 0.055,0.038, 15, P, alpha,6)
    corner(snout, 0.5); stroke(snout, PL, 1, alpha)

    -- Eye glow
    local eye = fr(parent, 0.5,0.5, 0.008,-.265, 0.012,0.012, 0, W, alpha,7)
    corner(eye, 1)
    local eyeInner = fr(parent, 0.5,0.5, 0.008,-.265, 0.006,0.006, 0, Color3.fromRGB(220,100,255), alpha,8)
    corner(eyeInner, 1)

    -- Horn 1
    local h1 = fr(parent, 0.5,1, -0.01,-.315, 0.012,0.04, -25, PL, alpha,6)
    corner(h1, 0.3); stroke(h1, W, 1, alpha)

    -- Horn 2
    local h2 = fr(parent, 0.5,1, 0.01,-.32, 0.009,0.032, -10, P, alpha,6)
    corner(h2, 0.3)

    -- ── WINGS ─────────────────────────────────────────────────────
    -- Left wing (large, swept back)
    local wl1 = fr(parent, 1,0.5, -0.13,-.15, 0.14,0.05, -35, PD, alpha,3)
    corner(wl1, 0.3); stroke(wl1, P, 1.5, alpha)
    grad(wl1, P, PD, 0)

    local wl2 = fr(parent, 1,0.5, -0.14,-.10, 0.13,0.04, -55, PD, alpha,3)
    corner(wl2, 0.3); stroke(wl2, P, 1, alpha)
    grad(wl2, P, PD, 0)

    local wl3 = fr(parent, 1,0.5, -0.12,-.06, 0.10,0.03, -72, PD, alpha,3)
    corner(wl3, 0.3)
    grad(wl3, P, PD, 0)

    -- Wing membrane left (thin connecting pieces)
    local wm1 = fr(parent, 1,0, -0.11,-.15, 0.08,0.10, -20, P, alpha+0.4,3)
    corner(wm1, 0.2)
    local wm2 = fr(parent, 1,0, -0.13,-.12, 0.06,0.08, -40, P, alpha+0.5,3)
    corner(wm2, 0.2)

    -- Right wing (smaller, front-facing)
    local wr1 = fr(parent, 0,0.5, 0.06,-.12, 0.10,0.04, 25, PD, alpha,3)
    corner(wr1, 0.3); stroke(wr1, P, 1.5, alpha)
    grad(wr1, PD, P, 0)

    local wr2 = fr(parent, 0,0.5, 0.07,-.08, 0.08,0.03, 42, PD, alpha,3)
    corner(wr2, 0.3)
    grad(wr2, PD, P, 0)

    -- ── TAIL ──────────────────────────────────────────────────────
    local t1 = fr(parent, 0.5,0, 0.02, .20, 0.04,0.10, 20, PD, alpha,4)
    corner(t1, 0.5); stroke(t1, P, 1, alpha)

    local t2 = fr(parent, 0.5,0, 0.04, .28, 0.03,0.08, 35, PD, alpha,4)
    corner(t2, 0.5)

    local t3 = fr(parent, 0.5,0, 0.06, .34, 0.02,0.05, 50, P, alpha,4)
    corner(t3, 0.5)

    -- Tail spike
    local ts = fr(parent, 0.5,0, 0.08, .38, 0.015,0.04, 60, PL, alpha,4)
    corner(ts, 0.3)

    -- ── CLAWS (feet) ──────────────────────────────────────────────
    local c1 = fr(parent, 0.5,0, -0.02, .20, 0.03,0.015, -30, PL, alpha,5)
    corner(c1, 0.5)
    local c2 = fr(parent, 0.5,0, 0.00, .21, 0.025,0.013, -15, PL, alpha,5)
    corner(c2, 0.5)
    local c3 = fr(parent, 0.5,0, 0.02, .20, 0.02,0.012, 0, PL, alpha,5)
    corner(c3, 0.5)

    -- ── SPINE RIDGE ───────────────────────────────────────────────
    for i=0,4 do
        local sp = fr(parent, 0.5,1, (-0.015+i*0.005), -.24+(i*0.06), 0.008,0.02, -5+(i*3), PL, alpha,6)
        corner(sp, 0.3)
    end

    -- ── GLOW AURA ─────────────────────────────────────────────────
    local aura = fr(parent, 0.5,0.5, -0.01,-.05, 0.22,0.42, 0, Color3.fromRGB(100,20,200), alpha+0.5,2)
    corner(aura, 0.5)

    return parts
end
