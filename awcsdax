    Sub.Font=Enum.Font.Gotham; Sub.TextSize=10; Sub.TextColor3=C_OFF.SUB; Sub.TextXAlignment=Enum.TextXAlignment.Left

    -- E badge
    local Badge=Instance.new("TextLabel",Card); Badge.Size=UDim2.new(0,26,0,20)
    Badge.Position=UDim2.new(1,-38,0.5,-10); Badge.BackgroundColor3=Color3.fromRGB(22,16,48)
    Badge.BorderSizePixel=0; Badge.Text="E"; Badge.Font=Enum.Font.GothamBlack; Badge.TextSize=12
    Badge.TextColor3=C_OFF.BRD
    Instance.new("UICorner",Badge).CornerRadius=UDim.new(0,8)

