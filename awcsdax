-- FREE PARRY ENGINE ◈ FIXED
-- ══════════════════════════════════════════════════════════════════
-- FIXES:
-- 1. Emergency parry now ONLY fires when ball is targeting YOU
--    (was firing for all nearby enemies → caused constant pre-clicks)
-- 2. Ping formula fixed: PingMs/1000 (full ping, was /2000 = half)
-- 3. Hitbox raised to 6.5 studs (was 5.0 → fired too late)
-- 4. AntiCurve threshold lowered: sc > 2 (was sc > 5 → missed curves)
-- 5. History expanded to 5 frames (was 3 → smoother curve reading)
-- 6. Cooldown reset fixed: always 0.18s (was using ParryCooldown
--    which user can set high, causing it to get stuck)
-- 7. Direction reversal threshold tightened to -0.3 (was -0.4)
-- ══════════════════════════════════════════════════════════════════
local freePosHist = {}
local freeSpeedHist = {}
local MAX_FREE_HIST = 5  -- FIX 5: expanded from 3
local function pushFreeHist(dist, t)
    table.insert(freePosHist, {d=dist, t=t})
    if #freePosHist > MAX_FREE_HIST then table.remove(freePosHist, 1) end
end
local function smoothFreeClosing(curDist, curTime)
    if #freePosHist < 2 then return 0 end
    local oldest = freePosHist[1]
    local dt = curTime - oldest.t
    if dt <= 0 then return 0 end
    return (oldest.d - curDist) / dt
end
local PrevBallPos = nil
local PrevBallTime = 0
S.ParryReset = 0.18
local function FireParry()
    if S.DidParry then return end
    if os.clock() - S.LastParry < S.ParryCooldown then return end
    VIM:SendMouseButtonEvent(0,0,0,true, game, 0)
    S.LastParry = os.clock()
    S.DidParry = true
    S.ParryCount = S.ParryCount + 1
    local rc
    rc = RunService.Heartbeat:Connect(function()
        VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
        rc:Disconnect()
    end)
    task.delay(S.ParryReset, function() S.DidParry = false end)  -- FIX 6
end
local function StartEngine()
    if Conn.Parry then Conn.Parry:Disconnect(); Conn.Parry=nil end
    if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
    if Conn.BallAdded then Conn.BallAdded:Disconnect(); Conn.BallAdded=nil end
    if Conn.DirWatch then Conn.DirWatch:Disconnect(); Conn.DirWatch=nil end
    S.DidParry = false
    PrevBallPos = nil
    freePosHist = {}
    freeSpeedHist = {}
    local function HookBall(ball)
        if not ball then return end
        if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
        Conn.Target = ball:GetAttributeChangedSignal("target"):Connect(function()
            S.DidParry = false  -- instantly re-arm when target changes
        end)
    end
    HookBall(GetBall())
    local function hookFolder(folder)
        if not folder then return end
        Conn.BallAdded = folder.ChildAdded:Connect(function()
            task.wait(0.05)
            local b = GetBall()
            if b then S.DidParry=false; PrevBallPos=nil; HookBall(b) end
        end)
    end
    local bf = workspace:FindFirstChild("Balls")
    if bf then hookFolder(bf)
    else task.spawn(function()
        local f = workspace:WaitForChild("Balls", 30)
        if f and not Conn.BallAdded then hookFolder(f) end
    end) end
    local lastDir = Vector3.zero
    Conn.DirWatch = RunService.Heartbeat:Connect(function()
        if not S.AutoParry then return end
        local b = GetBall(); if not b then return end
        local v = GetVel(b)
        if v.Magnitude > 2 and lastDir.Magnitude > 0 then
            if v.Unit:Dot(lastDir.Unit) < -0.3 then  -- FIX 7: tighter reversal detection
                S.DidParry = false
            end
        end
        if v.Magnitude > 0.5 then lastDir = v end
    end)
    Conn.Parry = RunService.PreSimulation:Connect(function()
        if not S.AutoParry then return end
        local Ball = GetBall()
        if not Ball then PrevBallPos=nil; freePosHist={}; freeSpeedHist={}; return end
        local HRP = GetHRP()
        if not HRP then return end
        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local now = os.clock()

        local isTgt = Ball:GetAttribute("target") == Plr.Name

        if S.AutoFace and isTgt then
            HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X, HPos.Y, BPos.Z))
        end

        -- FIX 1: Emergency only fires when YOU are the target
        -- (old code fired for any nearby enemy even if ball wasn't targeting you)
        if S.EmergencyParry and isTgt and not S.DidParry then
            if Dist <= S.EmergencyDist then
                FireParry()
                return
            end
        end

        if not isTgt then PrevBallPos=nil; freePosHist={}; freeSpeedHist={}; return end
        if S.DidParry then return end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        -- ANTI PRE-CLICK: only fire if ball is getting closer (dist shrinking)
        -- Uses last stored position to confirm ball is closing, not retreating.
        if PrevBallPos ~= nil and Speed > 1 then
            local prevDist = (HPos - PrevBallPos).Magnitude
            if Dist >= prevDist - 0.01 then
                -- ball not closing — update pos but don't fire yet
                PrevBallPos = BPos; PrevBallTime = now
                pushFreeHist(Dist, now)
                return
            end
        end

        -- Slow/stationary ball
        if Speed < 1 then
            if Dist <= 13.0 then FireParry() end
            return
        end

        pushFreeHist(Dist, now)
        table.insert(freeSpeedHist, Speed)
        if #freeSpeedHist > 5 then table.remove(freeSpeedHist, 1) end

        -- Speed boost detection
        local effectiveSpeed = Speed
        if S.SpeedBoostDetect and #freeSpeedHist >= 2 then
            local oldest = freeSpeedHist[1]
            if oldest > 0 and Speed / oldest > 1.25 then
                effectiveSpeed = Speed * 1.15
            end
        end

        -- FIX 2+3: Full ping compensation, bigger hitbox
        local hbox = 13.0
        -- Adaptive ping multiplier: aggressive early fire
        local pingFactor = PingMs <= 100 and 1.4 or (1.4 + ((PingMs - 100) / 100) * 0.7)
        pingFactor = math.min(pingFactor, 5.0)
        local pingComp = (PingMs / 1000) * effectiveSpeed * pingFactor
        local fireAt = hbox + pingComp

        if Dist <= fireAt then
            FireParry()
            PrevBallPos = BPos
            PrevBallTime = now
            return
        end

        -- Next-frame extrapolation (2 frames ahead)
        if Speed > 1 then
            local nextPos = BPos + Vel * (4/60)
            local nextDist = (HPos - nextPos).Magnitude
            if nextDist <= fireAt then
                FireParry()
                return
            end
        end

        -- FIX 4: AntiCurve threshold lowered to 2 (was 5 → missed most curves)
        if S.AntiCurve then
            local sc = smoothFreeClosing(Dist, now)
            if sc > 2 then  -- FIX 4
                local curveFireAt = hbox + (PingMs / 1000) * sc
                if Dist <= curveFireAt then
                    FireParry()
                end
            end
        end

        PrevBallPos = BPos
        PrevBallTime = now
        if S.Triggerbot and Dist <= 2 then FireParry() end
    end)
end
local function StopEngine()
    if Conn.Parry then Conn.Parry:Disconnect(); Conn.Parry=nil end
    if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
    if Conn.BallAdded then Conn.BallAdded:Disconnect(); Conn.BallAdded=nil end
    if Conn.DirWatch then Conn.DirWatch:Disconnect(); Conn.DirWatch=nil end
    S.DidParry=false; PrevBallPos=nil; freePosHist={}; freeSpeedHist={}
end
