        DeviceLabel.BackgroundTransparency=1; DeviceLabel.Font=Enum.Font.Code; DeviceLabel.TextSize=9
        DeviceLabel.TextColor3=Color3.fromRGB(40,100,140); DeviceLabel.TextXAlignment=Enum.TextXAlignment.Left; DeviceLabel.ZIndex=14
        pcall(function() DeviceLabel.Text="DEVICE  "..GetDeviceID():sub(1,22).."..." end)

        local VerifyBtn=Instance.new("TextButton",ScanCard); VerifyBtn.Size=UDim2.new(1,-64,0,44); VerifyBtn.Position=UDim2.new(0,32,0,174)
        VerifyBtn.BackgroundColor3=Color3.fromRGB(0,70,140); VerifyBtn.Text="◈  INITIATE SCAN  ◈"
        VerifyBtn.Font=Enum.Font.GothamBlack; VerifyBtn.TextSize=14; VerifyBtn.TextColor3=Color3.fromRGB(200,240,255); VerifyBtn.ZIndex=14
        Instance.new("UICorner",VerifyBtn).CornerRadius=UDim.new(0,12)
        local btnStroke=Instance.new("UIStroke",VerifyBtn); btnStroke.Thickness=1.8; btnStroke.Color=Color3.fromRGB(0,200,255); btnStroke.Transparency=0.2

        local CloseBtn=Instance.new("TextButton",ScanCard); CloseBtn.Size=UDim2.new(0,30,0,30); CloseBtn.Position=UDim2.new(1,-42,0,10)
        CloseBtn.BackgroundTransparency=1; CloseBtn.Text="×"; CloseBtn.Font=Enum.Font.GothamBold; CloseBtn.TextSize=24
        CloseBtn.TextColor3=Color3.fromRGB(160,160,200); CloseBtn.ZIndex=15

        local function closeScanner()
            rainActive=false; scanActive=false
            TweenService:Create(Overlay,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play()
            TweenService:Create(ScanCard,TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0),Position=UDim2.new(0.5,0,1.3,0)}):Play()
            task.wait(0.45); pcall(function() KSG:Destroy() end)
        end
        CloseBtn.MouseButton1Click:Connect(closeScanner)
        TweenService:Create(ScanCard,TweenInfo.new(0.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,460,0,228)}):Play()
        playSound2(4590662766,0.55,1.1)

        local function doVerify()
            local key=HiddenInput.Text:match("^%s*(.-)%s*$") or ""
            if #key<6 then Status.Text="◈  Key too short — try again"; Status.TextColor3=Color3.fromRGB(255,140,40); playSound2(6042053626,0.5,0.75); return end
            HiddenInput.TextEditable=false; VerifyBtn.Active=false
            Status.Text="◈  SCANNING — authenticating..."; Status.TextColor3=Color3.fromRGB(0,200,255)
            playSound2(9119713951,0.45,1.1)

            local scanning=true
            task.spawn(function()
                local t=0
                while scanning and ScanCard.Parent do
                    t=t+0.04; local col=Color3.fromHSV(t%1,0.9,0.95); cardStroke.Color=col; task.wait(0.04)
                end
            end)
            task.wait(1.6+math.random()*0.4); scanning=false

            local result=ValidateKey(key)
            if result=="ok" then
                playSound2(1847668471,0.75,1.0)
                Status.Text="◈  AUTHENTICATION SUCCESSFUL — PREMIUM GRANTED"
                Status.TextColor3=Color3.fromRGB(60,255,130)
                TweenService:Create(cardStroke,TweenInfo.new(0.35),{Color=Color3.fromRGB(50,255,130)}):Play()
                for _,cell in ipairs(slotCells) do
                    if cell.lbl.Text~="—" then
                        TweenService:Create(cell.lbl,TweenInfo.new(0.3),{TextColor3=Color3.fromRGB(50,255,130)}):Play()
                    end
                end
                local sFlash=Instance.new("Frame",KSG); sFlash.Size=UDim2.new(1,0,1,0)
                sFlash.BackgroundColor3=Color3.fromRGB(60,255,140); sFlash.BackgroundTransparency=0.6; sFlash.ZIndex=30
                TweenService:Create(sFlash,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play(); ScanDebris:AddItem(sFlash,0.8)
                PremiumUnlocked=true; PremiumActive=true
                Rayfield:Notify({Title="✨ Premium Activated",Content="Full access granted.",Duration=6,Image=4483362458})
                if S.AutoParry then StopEngine(); task.wait(0.08); P.AutoParry=true; StartPremiumEngine() end
                task.wait(2.0); closeScanner()
            else
                playSound2(6042053626,0.7,0.7)
                Status.Text=result=="locked_other" and "◈  DEVICE MISMATCH — ACCESS DENIED" or "◈  INVALID KEY"
                Status.TextColor3=Color3.fromRGB(255,60,60)
                TweenService:Create(cardStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(220,50,50)}):Play()
                task.wait(1.8)
                HiddenInput.Text=""; HiddenInput.TextEditable=true; VerifyBtn.Active=true
                Status.Text="◈  Try again..."; Status.TextColor3=Color3.fromRGB(0,160,210)
                cardStroke.Color=Color3.fromRGB(0,200,255)
            end
        end

        VerifyBtn.MouseButton1Click:Connect(doVerify)
        HiddenInput.FocusLost:Connect(function(enter) if enter then doVerify() end end)
        task.delay(0.6,function() pcall(function() HiddenInput:CaptureFocus() end) end)
    end)
end})

