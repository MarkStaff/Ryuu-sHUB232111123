        local InputLabel=Instance.new("TextLabel",ScanCard); InputLabel.Size=UDim2.new(1,-64,0,14); InputLabel.Position=UDim2.new(0,32,0,76)
        InputLabel.BackgroundTransparency=1; InputLabel.Text="▸ AUTHORIZATION KEY"
        InputLabel.Font=Enum.Font.GothamBlack; InputLabel.TextSize=9
        InputLabel.TextColor3=Color3.fromRGB(0,160,200); InputLabel.TextXAlignment=Enum.TextXAlignment.Left; InputLabel.ZIndex=14

        local SlotContainer=Instance.new("Frame",ScanCard); SlotContainer.Size=UDim2.new(1,-64,0,36); SlotContainer.Position=UDim2.new(0,32,0,92)
        SlotContainer.BackgroundColor3=Color3.fromRGB(5,14,26); SlotContainer.BackgroundTransparency=0.1; SlotContainer.BorderSizePixel=0; SlotContainer.ZIndex=14
        Instance.new("UICorner",SlotContainer).CornerRadius=UDim.new(0,10)
        local SlotStroke=Instance.new("UIStroke",SlotContainer); SlotStroke.Thickness=1.4; SlotStroke.Color=Color3.fromRGB(0,180,255); SlotStroke.Transparency=0.25

        local SLOT_COUNT=20; local slotCells={}
        for i=1,SLOT_COUNT do
            local cell=Instance.new("Frame",SlotContainer)
            cell.AnchorPoint=Vector2.new(0,0.5); cell.Position=UDim2.new((i-1)/SLOT_COUNT,2,0.5,0)
            cell.Size=UDim2.new(1/SLOT_COUNT,-4,0,20); cell.BackgroundColor3=Color3.fromRGB(0,30,60)
            cell.BackgroundTransparency=0.3; cell.BorderSizePixel=0; cell.ZIndex=15
            Instance.new("UICorner",cell).CornerRadius=UDim.new(0,4)
            local cellChar=Instance.new("TextLabel",cell); cellChar.Size=UDim2.new(1,0,1,0); cellChar.BackgroundTransparency=1
            cellChar.Text="—"; cellChar.Font=Enum.Font.Code; cellChar.TextSize=11; cellChar.TextColor3=Color3.fromRGB(0,80,120); cellChar.ZIndex=16
            slotCells[i]={frame=cell,lbl=cellChar}
        end

        local Cursor=Instance.new("Frame",SlotContainer); Cursor.AnchorPoint=Vector2.new(0,0.5); Cursor.Size=UDim2.new(0,2,0,22); Cursor.Position=UDim2.new(0,2,0.5,0)
        Cursor.BackgroundColor3=Color3.fromRGB(0,220,255); Cursor.BorderSizePixel=0; Cursor.ZIndex=17
        task.spawn(function() while Cursor.Parent do pcall(function() Cursor.BackgroundTransparency=0 end); task.wait(0.5); pcall(function() Cursor.BackgroundTransparency=1 end); task.wait(0.5) end end)

        local HiddenInput=Instance.new("TextBox",ScanCard); HiddenInput.Size=UDim2.new(1,-64,0,36); HiddenInput.Position=UDim2.new(0,32,0,92)
        HiddenInput.BackgroundTransparency=1; HiddenInput.Text=""; HiddenInput.TextTransparency=1
        HiddenInput.PlaceholderText=""; HiddenInput.Font=Enum.Font.Code; HiddenInput.TextSize=11
        HiddenInput.ClearTextOnFocus=false; HiddenInput.ZIndex=18; HiddenInput.TextColor3=Color3.fromRGB(0,0,0)

        local function UpdateSlots(text)
            local len=math.min(#text,SLOT_COUNT)
            for i=1,SLOT_COUNT do
                local cell=slotCells[i]
                if i<=len then
                    local ch=text:sub(i,i); local hue=math.clamp((i/len)*0.33,0,0.33)
                    cell.lbl.Text=ch; cell.lbl.TextColor3=Color3.fromHSV(hue,1,1)
                    cell.frame.BackgroundColor3=Color3.fromHSV(hue,0.9,0.2); cell.frame.BackgroundTransparency=0.1
                else
                    cell.lbl.Text="—"; cell.lbl.TextColor3=Color3.fromRGB(0,60,100)
                    cell.frame.BackgroundColor3=Color3.fromRGB(0,20,45); cell.frame.BackgroundTransparency=0.4
                end
            end
            local cursorCell=math.min(len+1,SLOT_COUNT)
            Cursor.Position=UDim2.new((cursorCell-1)/SLOT_COUNT,3,0.5,0)
        end
        HiddenInput:GetPropertyChangedSignal("Text"):Connect(function() UpdateSlots(HiddenInput.Text) end)

        local Status=Instance.new("TextLabel",ScanCard); Status.Size=UDim2.new(1,-64,0,18); Status.Position=UDim2.new(0,32,0,136)
        Status.BackgroundTransparency=1; Status.Text="◈  Awaiting authorization key..."
