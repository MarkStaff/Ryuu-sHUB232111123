local function BuildTrajectoryESP()
    if TrajSG then pcall(function() TrajSG:Destroy() end) end
    TrajSG = Instance.new("ScreenGui")
    TrajSG.Name = "RyuuTraj"; TrajSG.ResetOnSpawn = false
    TrajSG.IgnoreGuiInset = true; TrajSG.DisplayOrder = 9989
