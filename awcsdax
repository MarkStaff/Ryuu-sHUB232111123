-- UPGRADED PREMIUM GAME ENGINE
-- ══════════════════════════════════════════════════════════════════
--
-- WHAT CHANGED vs old:
--
-- 1. NO PRE-CLICK: premFireDist now has a hard cap like the free
--    engine. Old premium had no cap — high accuracy (>100) added
--    "frames ahead" bonus that could push fireD to 20+ studs.
--    New: hard cap at HitboxTarget + 12 + pingC, acc>100 adds
--    a smarter early-fire by reducing the post-fire lock window
--    instead of bloating fireD.
--
-- 2. CURVE SURVIVAL: Same Bezier predictor as free engine.
--    Premium uses 7 frames (vs 5 for free) for sharper curves.
--    Critical fix: old engine computed angVel from only the last
--    2 velocity samples which gave garbage estimates when the ball
--    had just changed direction. New uses last 4 samples weighted.
--
-- 3. DUEL/CLASH MODE: Same as free engine but more sensitive:
--    clash range extended to 28 studs, COOLDOWN reduced to 0.12s,
--    and uses a "ball flip detector" — fires instantly when the
--    ball changes direction from away to toward within 3 frames.
--    This is the magic for the "face-to-face accurate spam" feel.
--
-- 4. VELOCITY ANGLE CHECK: New guard — only fires if ball's
--    velocity vector is actually pointing toward the player within
--    35°. Prevents firing when ball curves past you without hitting.
--    This was the biggest source of wasted clicks in the old engine.
--
-- 5. SMOOTH REARM: Instead of resetting didParry on a fixed timer,
--    premium now rearms the moment the ball's closing rate goes
--    negative (ball moving away) or target changes. This means
--    consecutive rapid-fire clashes in a row work perfectly.
-- ══════════════════════════════════════════════════════════════════
local PremConn = {}
local PremH    = { pos={}, spd={}, vel={} }
local PREM_MAX = 28

local function resetPrem()
    PremH = { pos={}, spd={}, vel={} }
    PremFire.didParry = false
end

local function pushPrem(dist, vel, t)
    local spd = vel.Magnitude
    local function push(tbl, val)
        table.insert(tbl, val)
        if #tbl > PREM_MAX then table.remove(tbl, 1) end
    end
    push(PremH.pos, {d=dist, t=t})
    push(PremH.spd, {s=spd,  t=t})
    push(PremH.vel, {v=vel,  t=t})
end

local function premFireDist(speed, closing, pingC, curve, accel)
    local htb  = P.HitboxTarget or 4.0
    local base = htb + pingC + (P.EarlyOffset or 0)

    if     speed > 290 then base = base + (speed-290)*0.058
    elseif speed > 220 then base = base + (speed-220)*0.042
    elseif speed > 155 then base = base + (speed-155)*0.028
    elseif speed > 100 then base = base + (speed-100)*0.015 end

    if     closing > 75 then base = base + (closing-75)*0.092
    elseif closing > 40 then base = base + (closing-40)*0.052 end

    -- Curve bonus with tighter ceiling to avoid pre-click
    if curve > 6  then base = base + math.min((curve-6)*0.075, 6.5) end
    if accel > 30 then base = base + math.min((accel-30)*0.018, 3.5) end

    -- HARD CAP
    local cap = htb + 12.0 + pingC
    return math.min(base, cap)
end

-- Weighted angular velocity from last 4 vel samples (better curve estimate)
local function WeightedAngVel(velHistory)
    local n = #velHistory
    if n < 4 then return Vector3.zero end
    local totalAV = Vector3.zero
    local totalW  = 0
    for i = n-2, n do
        local a = velHistory[i-1]
        local b = velHistory[i]
        if a and b then
            local dt = b.t - a.t
            if dt > 0.001 then
                local w = math.exp((i - n) * 0.5) -- recent = higher weight
                totalAV = totalAV + (b.v - a.v) / dt * w
                totalW  = totalW + w
            end
        end
    end
    return totalW > 0 and (totalAV / totalW) or Vector3.zero
end

-- Velocity angle toward player check
local function BallAimedAtMe(ballPos, vel, hrpPos, angleDeg)
    if vel.Magnitude < 5 then return true end -- stationary = ignore check
    local toBall = (hrpPos - ballPos).Unit
    local dot    = vel.Unit:Dot(toBall)
    return dot >= math.cos(math.rad(angleDeg))
end

-- Bezier position predictor (reused, same as free engine)
local function BezierPredictPrem(velHistory, ballPos, steps)
    local n = #velHistory
    if n < 3 then return nil end
    local v2 = velHistory[n].v
    local v1 = velHistory[n-1].v
    local dt  = 1/60
    local p0  = ballPos - v1*dt
    local p1  = ballPos
    local p2  = ballPos + v2*dt*1.5
    local results = {}
    for step = 1, steps do
        local t = step / steps
        results[step] = Vector3.new(
            (1-t)^2*p0.X + 2*(1-t)*t*p1.X + t^2*p2.X,
            (1-t)^2*p0.Y + 2*(1-t)*t*p1.Y + t^2*p2.Y,
            (1-t)^2*p0.Z + 2*(1-t)*t*p1.Z + t^2*p2.Z
        )
    end
    return results
end

-- Ball flip detector: was going away, now coming toward us
local function DetectBallFlip(posHistory)
    local n = #posHistory
    if n < 4 then return false end
    -- Check if distance increased 2 frames ago and is now decreasing
    local old3 = posHistory[n-3] and posHistory[n-3].d or 999
    local old2 = posHistory[n-2] and posHistory[n-2].d or 999
    local old1 = posHistory[n-1] and posHistory[n-1].d or 999
    local cur  = posHistory[n].d
    local wasIncreasing = old2 > old3
    local nowDecreasing = cur < old1 and cur < old2
    return wasIncreasing and nowDecreasing
end

local function StartPremiumGameEngine()
    if PremConn.main then PremConn.main:Disconnect() end
    resetPrem(); BuildParryIndicator()

    PremConn.main = RunService.PreSimulation:Connect(function()
        if not P.AutoParry then return end
        pcall(updateSmoothedPing)

        local ball = GetBall()
        if not ball then resetPrem(); return end
        local hrp = GetHRP(); if not hrp then return end

        local tgt   = ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if isTgt and P.AutoFace then
            pcall(function()
                hrp.CFrame = CFrame.lookAt(hrp.Position,
                    Vector3.new(ball.Position.X, hrp.Position.Y, ball.Position.Z))
            end)
        end

        if not isTgt then resetPrem(); UpdateParryIndicator(99,1,false); return end

        local ballPos = ball.Position
        local dist    = (hrp.Position - ballPos).Magnitude
        local vel     = GetVel(ball)
        local now     = os.clock()
        pushPrem(dist, vel, now)

        -- ── SMOOTH REARM: if ball moved away since last fire, rearm ──
        -- This allows consecutive clashes without waiting for reset timer
        if PremFire.didParry and #PremH.pos >= 3 then
            local n = #PremH.pos
            if PremH.pos[n].d > PremH.pos[n-1].d + 0.5 then
                -- Ball is moving away from us — safe to rearm
                PremFire.didParry = false
            end
        end

        -- ── CLASH / DUEL MODE ────────────────────────────────────
        local inClash = false
        if #PremH.pos >= 4 then
            -- Premium uses wider clash range
            local savedRange = ClashState.RANGE
            ClashState.RANGE = 28
            inClash = DetectClash()
            ClashState.RANGE = savedRange
        end

        -- Ball-flip fire: ball just reversed direction toward us
        if #PremH.pos >= 4 and not PremFire.didParry then
            if DetectBallFlip(PremH.pos) then
                local closing = RecentClosingRate(PremH.pos)
                if closing > 10 then
                    -- Flip detected — fire immediately if close enough
                    local flipFireD = (P.HitboxTarget or 4.0) + 9.0 + smoothedPing * 130
                    if dist <= flipFireD then
                        PremiumFire(ball); resetPrem()
                        UpdateParryIndicator(dist, flipFireD, true); return
                    end
                end
            end
        end

        if inClash and not PremFire.didParry and
           now - ClashState.lastClashFire > 0.12 then
            local closing = RecentClosingRate(PremH.pos)
            local clashFireD = (P.HitboxTarget or 4.0) + 8.5 + smoothedPing * 120
            if closing > 12 and dist <= clashFireD then
                ClashState.lastClashFire = now
                PremiumFire(ball); resetPrem()
                UpdateParryIndicator(dist, clashFireD, true); return
            end
        end

        -- ── EMERGENCY ────────────────────────────────────────────
        local emDist = 3.2 + smoothedPing * 140
        if P.GodEmergency and not PremFire.didParry and dist <= emDist then
            PremiumFire(ball); resetPrem(); UpdateParryIndicator(dist,dist,true); return
        end

        if PremFire.didParry then return end
        if now - PremFire.lastParry < 0.055 then return end

        local speed   = vel.Magnitude
        local closing = RecentClosingRate(PremH.pos)
        local accel   = AvgAccel(PremH.spd, 6)
        local curve   = CurveRate(PremH.vel, 5)
        local spike   = SpikeMul(PremH.spd)
        local proj    = (speed + math.max(0, accel) * 0.025) * spike
        local pingC   = smoothedPing * proj * 1.45
        if smoothedPing > 0.13 then pingC = pingC * 1.18 end

        local fireD = premFireDist(proj, closing, pingC, curve, accel)

        -- Acc > 100: reduce post-fire lockout instead of bloating fireD
        -- This is safer than the old "frames ahead" trick
        local acc = math.clamp(PremAccuracy or 100, 1, 150)
        if acc > 100 then
            local lockReduction = ((acc - 100) / 50) * 0.06  -- up to 60ms reduction
            if PremFire.resetConn then
                task.cancel(PremFire.resetConn)
                PremFire.resetConn = task.delay(
                    math.max(0.04, (S.ParryReset or 0.10) - lockReduction),
                    function() PremFire.didParry=false; PremFire.resetConn=nil end
                )
            end
        end

        UpdateParryIndicator(dist, fireD, false)

        -- ── VELOCITY ANGLE GUARD (anti-wasted-click) ─────────────
        -- Only proceed if ball is actually aimed within 35° of us
        if speed > 20 and not BallAimedAtMe(ballPos, vel, hrp.Position, 35) then
            -- Ball curving past us, not at us — skip this frame
            return
        end

        -- ── DIRECT DISTANCE CHECK ────────────────────────────────
        if dist <= fireD then
            PremiumFire(ball); resetPrem(); UpdateParryIndicator(dist,fireD,true); return
        end

        -- ── KINEMATIC LOOKAHEAD (6 frames, tighter tolerance) ────
        if closing > 10 and speed > 30 then
            for step = 1, 6 do
                local dt    = step / 60
                local pDist = dist - closing*dt - 0.5*math.max(0,accel)*dt*dt
                local tol   = 0.12 * step  -- much tighter than old 0.38
                if pDist <= fireD + tol then
                    PremiumFire(ball); resetPrem(); UpdateParryIndicator(dist,fireD,true); return
                end
            end
        end

        -- ── CURVE LOOKAHEAD (Bezier, 7 frames) ───────────────────
        if curve > 5 and #PremH.vel >= 4 then
            local predicted = BezierPredictPrem(PremH.vel, ballPos, 7)
            if predicted then
                for step, pPos in ipairs(predicted) do
                    if (hrp.Position - pPos).Magnitude <= fireD + 0.15*step then
                        -- Extra check: is predicted position still in front of us?
                        local toP  = (pPos - hrp.Position)
                        local proj2 = hrp.CFrame.LookVector:Dot(toP.Unit)
                        if proj2 > -0.3 then  -- within 108° in front
                            PremiumFire(ball); resetPrem(); UpdateParryIndicator(dist,fireD,true); return
                        end
                    end
                end
            end
        end
    end)
end

local function StopPremiumGameEngine()
    if PremConn.main then PremConn.main:Disconnect(); PremConn.main = nil end
    resetPrem()
end

