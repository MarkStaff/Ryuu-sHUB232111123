-- ── 12. ANTI-BLOCK (spam prevention bypass) ──────────────────────
-- Auto-detects when your parry key is eaten (e.g. clicked too fast)
-- and re-fires once with a 0.05s delay to push it through.
local function StartAntiBlock()
    if AB.conn then AB.conn:Disconnect() end
    local prevCount = S.ParryCount
    AB.conn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local now = os.clock()
            -- If we fired but parry count didn't go up in 0.15s, re-fire
            if S.DidParry and now - S.LastParry > 0.1 and now - AB.last > 0.3 then
                if S.ParryCount == prevCount then
                    task.delay(0.05, function()
                        if not S.DidParry then return end
                        VIM:SendMouseButtonEvent(0,0,0,true,game,0)
                        task.wait(0.02)
                        VIM:SendMouseButtonEvent(0,0,0,false,game,0)
                        AB.last = os.clock()
                    end)
                end
            end
            prevCount = S.ParryCount
        end)
    end)
end
local function StopAntiBlock()
    if AB.conn then AB.conn:Disconnect(); AB.conn = nil end
end

