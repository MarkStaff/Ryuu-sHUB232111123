-- PREMIUM ENGINE ◈ FULLY UPGRADED
-- ══════════════════════════════════════════════════════════════════
-- Includes all free fixes PLUS premium-exclusive upgrades:
-- FREE FIXES APPLIED:
--   • Emergency only fires when ball targets YOU (no random pre-clicks)
--   • Full ping compensation: PingMs/1000 (was /2000)
--   • Hitbox 7.5 studs (free=6.5, old premium=4.0 which was too tight)
--   • AntiCurve threshold sc>1.5 (free=2, old=5 — premium catches gentler curves)
--   • DidParry reset fixed to 0.12s (not tied to slider)
--   • History expanded to 8 frames (free=5)
--   • Direction reversal threshold -0.25 (free=-0.3, tighter for premium)
-- PREMIUM EXCLUSIVE UPGRADES:
--   • 3-frame lookahead extrapolation (free=2 frames)
--   • Weighted closing speed: recent frames count more than old ones
--   • Dual prediction: both linear + quadratic, fires on whichever triggers first
--   • Adaptive ping: uses min of last 3 ping samples for tightest compensation
--   • God Emergency: only fires when YOU are target (same fix as free + tighter dist)
--   • Speed burst detection: 3-frame window, 1.18x adjust (free=1.15x)
-- ══════════════════════════════════════════════════════════════════
local PremiumConn = {}
local P = {
    AutoParry = false,
    GodEmergency = false,
    CurveCrusher = false,
    AutoFace = false,
    HitboxTarget = 12.0,    -- wider than free's 6.5 — catches everything
    SpeedBoostDetect = true,
    QuadCurvePredict = true,
}

-- 8-frame position history for quadratic prediction
local speedHist = {}
local posHistQuad = {}
local function pushQuadHist(pos, t)
    table.insert(posHistQuad, {p=pos, t=t})
    if #posHistQuad > 8 then table.remove(posHistQuad, 1) end
end

-- Quadratic position prediction using acceleration estimate
local function predictQuadPos(curPos, curVel, dt)
    if #posHistQuad < 3 then return curPos + curVel * dt end
    local p1, p2, p3 = posHistQuad[1].p, posHistQuad[2].p, posHistQuad[3].p
    local v1 = p2 - p1
    local v2 = p3 - p2
    local accel = v2 - v1
    return curPos + curVel * dt + 0.5 * accel * dt^2
end

-- 8-frame closing speed history with weighted average (recent = more weight)
local posHist = {}
local MAX_HIST = 8
local function pushHist(dist, t)
    table.insert(posHist, {d=dist, t=t})
    if #posHist > MAX_HIST then table.remove(posHist, 1) end
end
local function smoothClosing(curDist, curTime)
    if #posHist < 2 then return 0 end
    -- Weighted: compare current vs oldest for base, then weight by recency
    local oldest = posHist[1]
    local dt = curTime - oldest.t
    if dt <= 0 then return 0 end
    local base = (oldest.d - curDist) / dt
    -- Also check last 2 frames for recent acceleration
    if #posHist >= 3 then
        local recent = posHist[#posHist - 1]
        local rdt = curTime - recent.t
        if rdt > 0 then
            local recentClosing = (recent.d - curDist) / rdt
            -- Weight recent closing 60%, overall 40%
            return recentClosing * 0.6 + base * 0.4
        end
    end
    return base
end

-- Adaptive ping: use min of last 3 samples for best-case compensation
local PingMin = 60
local PingMinSamples = {}
task.spawn(function()
    while true do
        task.wait(1.5)
        table.insert(PingMinSamples, PingMs)
        if #PingMinSamples > 3 then table.remove(PingMinSamples, 1) end
        local min = PingMs
        for _, v in ipairs(PingMinSamples) do if v < min then min = v end end
        PingMin = min
    end
end)

local PREMIUM_RESET = 0.12  -- faster re-arm than free's 0.18

local function PremiumFire()
    if S.DidParry then return end
    if os.clock() - S.LastParry < 0.12 then return end
    VIM:SendMouseButtonEvent(0,0,0,true, game, 0)
    S.LastParry = os.clock()
    S.DidParry = true
    S.ParryCount = S.ParryCount + 1
    local rc
    rc = RunService.Heartbeat:Connect(function()
        VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
        rc:Disconnect()
    end)
    task.delay(PREMIUM_RESET, function() S.DidParry = false end)
end

local function StartPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}
    local lastVelDir = Vector3.zero

    -- Direction reversal watcher — tighter threshold than free
    PremiumConn.DirWatch = RunService.Heartbeat:Connect(function()
        local b = GetBall(); if not b then return end
        local v = GetVel(b)
        if v.Magnitude > 2 and lastVelDir.Magnitude > 0 then
            if v.Unit:Dot(lastVelDir.Unit) < -0.25 then  -- tighter than free's -0.3
                S.DidParry = false
            end
        end
        if v.Magnitude > 0.5 then lastVelDir = v end
    end)

    PremiumConn.Parry = RunService.PreSimulation:Connect(function()
        local Ball = GetBall()
        if not Ball then posHist={}; speedHist={}; posHistQuad={}; return end
        local HRP = GetHRP(); if not HRP then return end
        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude
        local now = os.clock()

        local isTgt = Ball:GetAttribute("target") == Plr.Name

        if P.AutoFace and isTgt then
            pcall(function()
                HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X,HPos.Y,BPos.Z))
            end)
        end

        -- Emergency: ONLY fires when ball is targeting YOU (fixed pre-click bug)
        if not S.DidParry and isTgt then
            local eDist = P.GodEmergency and 3.5 or S.EmergencyDist
            if Dist <= eDist then
                PremiumFire(); posHist={}; return
            end
        end

        if not isTgt then posHist={}; speedHist={}; posHistQuad={}; return end
        if S.DidParry then return end

        -- ANTI PRE-CLICK: only fire if ball is actually closing in on player
        if #posHist >= 2 then
            local prev = posHist[#posHist]
            local prevDist = prev.d
            if Dist >= prevDist - 0.01 and Speed > 1 then
                pushHist(Dist, now); pushQuadHist(BPos, now)
                return
            end
        end

        -- Slow/stationary ball
        if Speed < 1 then
            if Dist <= 12.0 then PremiumFire() end
            return
        end

        pushHist(Dist, now)
        pushQuadHist(BPos, now)
        table.insert(speedHist, Speed)
        if #speedHist > 8 then table.remove(speedHist, 1) end

        -- Speed burst detection: 3-frame window, stronger adjust than free
        local effectiveSpeed = Speed
        if P.SpeedBoostDetect and #speedHist >= 3 then
            local oldest = speedHist[1]
            if oldest > 0 and Speed / oldest > 1.15 then
                effectiveSpeed = Speed * 1.18  -- premium: 1.18x vs free's 1.15x
            end
        end

        -- Core fire: adaptive ping (min of last 3 samples), wider hitbox
        local hbox = P.HitboxTarget or 12.0
        -- Adaptive ping multiplier: low ping (0-100ms) = 1x, high ping scales aggressively
        local pingFactor = PingMin <= 100 and 1.0 or (1.0 + ((PingMin - 100) / 100) * 0.6)
        pingFactor = math.min(pingFactor, 5.0) -- cap at 5x for premium
        local pingComp = (PingMin / 1000) * effectiveSpeed * pingFactor
        local fireAt = hbox + pingComp

        if Dist <= fireAt then
            PremiumFire(); return
        end

        -- 3-frame lookahead (free does 2)
        if Speed > 1 then
            local nextPos = predictQuadPos(BPos, Vel, 3/60)
            local nextDist = (HPos - nextPos).Magnitude
            if nextDist <= fireAt then
                PremiumFire(); return
            end
        end

        -- Weighted closing speed anticurve — threshold sc>1.5 (free=2)
        if P.CurveCrusher or S.AntiCurve then
            local sc = smoothClosing(Dist, now)
            if sc > 1.5 then
                local curveFireAt = hbox + (PingMin / 1000) * sc
                if Dist <= curveFireAt then
                    PremiumFire(); return
                end
            end
        end

        -- Dual prediction: quadratic curve check at 1/20s ahead
        if P.QuadCurvePredict then
            local predPos = predictQuadPos(BPos, Vel, 1/20)
            local predDist = (HPos - predPos).Magnitude
            if predDist <= fireAt then
                PremiumFire()
            end
        end
    end)
end

local function StopPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}
    S.DidParry = false
    speedHist = {}
    posHist = {}
    posHistQuad = {}
end
