    local Close=Instance.new("TextButton",Card); Close.Size=UDim2.new(0,20,0,20)
    Close.Position=UDim2.new(1,-24,0,6); Close.BackgroundTransparency=1; Close.Text="✕"
    Close.Font=Enum.Font.GothamBold; Close.TextSize=13; Close.TextColor3=Color3.fromRGB(130,110,190)

    -- Drag
    local dragging,dragStart,startPos=false,nil,nil
    Card.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            dragging=true; dragStart=input.Position; startPos=Card.Position
            TweenService:Create(Card,TweenInfo.new(0.1),{Size=UDim2.new(0,184,0,61)}):Play()
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then
            local delta=input.Position-dragStart
            local vs=Cam.ViewportSize
            local nx=math.clamp(startPos.X.Offset+delta.X,-200,vs.X-20)
            local ny=math.clamp(startPos.Y.Offset+delta.Y,-100,vs.Y-80)
            Card.Position=UDim2.new(startPos.X.Scale,nx,startPos.Y.Scale,ny)
            Shadow.Position=UDim2.new(startPos.X.Scale,nx+3,startPos.Y.Scale,ny+3)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            dragging=false
            TweenService:Create(Card,TweenInfo.new(0.15),{Size=UDim2.new(0,188,0,64)}):Play()
        end
    end)

    local TIF=TweenInfo.new(0.18,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    local dotPulseConn=nil

    local function updateVisuals(on)
        local c=on and C_ON or C_OFF
        TweenService:Create(Card,TIF,{BackgroundColor3=c.BG}):Play()
        TweenService:Create(MSStroke,TIF,{Color=c.BRD}):Play()
        TweenService:Create(Tit,TIF,{TextColor3=c.TXT}):Play()
        TweenService:Create(Sub,TIF,{TextColor3=c.SUB}):Play()
        TweenService:Create(Dot,TIF,{BackgroundColor3=c.DOT}):Play()
        TweenService:Create(Accent,TIF,{BackgroundColor3=c.BRD}):Play()
        TweenService:Create(Badge,TIF,{TextColor3=c.BRD}):Play()
        Sub.Text=on and "ON  ·  SPAMMING" or "OFF  ·  Press E to toggle"

        if dotPulseConn then dotPulseConn:Disconnect(); dotPulseConn=nil end
        if on then
            local big=false
            dotPulseConn=RunService.Heartbeat:Connect(function()
                pcall(function()
                    TweenService:Create(Dot,TweenInfo.new(0.35,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),
                        {Size=big and UDim2.new(0,11,0,11) or UDim2.new(0,15,0,15),
                         Position=big and UDim2.new(0,15,0.5,-5.5) or UDim2.new(0,13,0.5,-7.5)}):Play()
                    big=not big
                end)
                task.wait(0.35)
            end)
        end
    end

    local function doStart()
        if MSThr then return end
        MSThr=RunService.Heartbeat:Connect(function()
            if not MSOn then MSThr:Disconnect(); MSThr=nil; return end
            VIM:SendMouseButtonEvent(0,0,0,true,game,0)
            VIM:SendMouseButtonEvent(0,0,0,false,game,0)
        end)
    end
    local function doStop()
        MSOn=false; if MSThr then MSThr:Disconnect(); MSThr=nil end
    end
    local function toggle()
        MSOn=not MSOn; updateVisuals(MSOn)
        if MSOn then doStart() else doStop() end
    end

    UIS.InputBegan:Connect(function(input)
        if input.KeyCode==Enum.KeyCode.E and MSSG.Enabled then toggle() end
    end)
    Card.MouseButton1Click:Connect(toggle)
    Close.MouseButton1Click:Connect(function()
        doStop(); updateVisuals(false); MSSG.Enabled=false
    end)
    Close.MouseEnter:Connect(function()
        TweenService:Create(Close,TweenInfo.new(0.12),{TextColor3=Color3.fromRGB(255,90,90)}):Play()
    end)
    Close.MouseLeave:Connect(function()
        TweenService:Create(Close,TweenInfo.new(0.12),{TextColor3=Color3.fromRGB(130,110,190)}):Play()
    end)

    _G.RyuuOpenManualSpam=function()
