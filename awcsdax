                TweenService:Create(ScanCard,TweenInfo.new(0.35,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0),Position=UDim2.new(0.5,0,1.3,0)}):Play()
                TweenService:Create(OrbContainer,TweenInfo.new(0.4),{Size=UDim2.new(0,0,0,0)}):Play()
                task.wait(0.45); pcall(function() KSG:Destroy() end)
            end
            CloseBtn.MouseButton1Click:Connect(closeScanner)

            TweenService:Create(ScanCard,TweenInfo.new(0.55,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,460,0,228)}):Play()
            playSound2(4590662766,0.55,1.1)

            task.spawn(function()
                local rot=0
                while ScanCard.Parent and scanActive do
                    rot=(rot+1.5)%360; pcall(function() AccentGrad.Rotation=rot; HGrad.Rotation=rot*0.3 end); task.wait(0.016)
                end
            end)

            local function doVerify()
                local key=HiddenInput.Text:match("^%s*(.-)%s*$") or ""
                if #key<6 then
                    Status.Text="◈  Key too short — try again"
                    Status.TextColor3=Color3.fromRGB(255,140,40)
                    playSound2(6042053626,0.5,0.75)
                    return
                end

                HiddenInput.TextEditable=false; VerifyBtn.Active=false
                Status.Text="◈  SCANNING  —  authenticating..."; Status.TextColor3=Color3.fromRGB(0,200,255)

                playSound2(9119713951,0.45,1.1)

                ScanBeam.Visible=true; ScanBeam.Position=UDim2.new(0,28,0,92)
                TweenService:Create(ScanBeam,TweenInfo.new(1.4,Enum.EasingStyle.Quad,Enum.EasingDirection.InOut),
                    {Position=UDim2.new(1,-38,0,92)}):Play()

                local scanning=true
                task.spawn(function()
                    local t=0
                    while scanning and ScanCard.Parent do
                        t=t+0.04
                        local col=Color3.fromHSV(t%1,0.9,0.95)
                        cardStroke.Color=col; orbStroke.Color=col
                        task.wait(0.04)
                    end
                end)

                task.wait(1.6+math.random()*0.4)
                scanning=false; ScanBeam.Visible=false

                local result=ValidateKey(key)

                if result=="ok" then
                    playSound2(1847668471,0.75,1.0)
                    task.delay(0.1,function() playSound2(1847668590,0.65,1.35) end)
                    task.delay(0.25,function() playSound2(1847668590,0.5,1.65) end)
                    task.delay(0.4,function() playSound2(1847668590,0.4,1.9) end)

                    Status.Text="◈  AUTHENTICATION SUCCESSFUL — PREMIUM GRANTED"
                    Status.TextColor3=Color3.fromRGB(60,255,130)

                    TweenService:Create(cardStroke,TweenInfo.new(0.35),{Color=Color3.fromRGB(50,255,130)}):Play()
                    TweenService:Create(orbStroke,TweenInfo.new(0.35),{Color=Color3.fromRGB(80,255,160)}):Play()
                    TweenService:Create(SlotStroke,TweenInfo.new(0.35),{Color=Color3.fromRGB(50,255,130)}):Play()
                    TweenService:Create(btnStroke,TweenInfo.new(0.35),{Color=Color3.fromRGB(50,255,130)}):Play()
                    TweenService:Create(CardAccentTop,TweenInfo.new(0.35),{BackgroundColor3=Color3.fromRGB(50,255,130)}):Play()

                    for _,cell in ipairs(slotCells) do
                        if cell.lbl.Text~="—" then
                            TweenService:Create(cell.lbl,TweenInfo.new(0.3),{TextColor3=Color3.fromRGB(50,255,130)}):Play()
                            TweenService:Create(cell.frame,TweenInfo.new(0.3),{BackgroundColor3=Color3.fromRGB(0,60,20)}):Play()
                        end
                    end

                    for i=1,24 do
                        task.delay(i*0.03,function()
                            local p=Instance.new("Frame",KSG)
                            p.AnchorPoint=Vector2.new(0.5,0.5); p.Position=UDim2.new(0.5,0,0.5,60); p.Size=UDim2.new(0,8,0,8)
                            local hue=i/24; p.BackgroundColor3=Color3.fromHSV(hue*0.35,1,1); p.BackgroundTransparency=0.1
                            p.BorderSizePixel=0; p.ZIndex=25; Instance.new("UICorner",p).CornerRadius=UDim.new(1,0)
                            TweenService:Create(p,TweenInfo.new(1.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{
                                Position=UDim2.new(0.5,math.random(-250,250),0.5,math.random(-200,200)+60),
                                Size=UDim2.new(0,0,0,0),BackgroundTransparency=1}):Play()
                            ScanDebris:AddItem(p,1.4)
                        end)
                    end

                    local sFlash=Instance.new("Frame",KSG); sFlash.Size=UDim2.new(1,0,1,0); sFlash.BackgroundColor3=Color3.fromRGB(60,255,140); sFlash.BackgroundTransparency=0.6; sFlash.ZIndex=30
                    TweenService:Create(sFlash,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play(); ScanDebris:AddItem(sFlash,0.8)

                    PremiumUnlocked=true; PremiumActive=true
                    task.spawn(RemovePremiumLock)
                    Rayfield:Notify({Title="✨ Premium Activated",Content="Full access granted. Enjoy Ryuu V2 Premium.",Duration=6,Image=4483362458})

                    if S.AutoParry then
                        StopEngine(); task.wait(0.08); P.AutoParry=true; StartPremiumEngine()
                    end

                    task.wait(2.0); closeScanner()
                else
                    playSound2(6042053626,0.7,0.7)
                    Status.Text=result=="locked_other" and "◈  DEVICE MISMATCH — ACCESS DENIED" or "◈  INVALID KEY — AUTHORIZATION FAILED"
                    Status.TextColor3=Color3.fromRGB(255,60,60)

                    TweenService:Create(cardStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(220,50,50)}):Play()
                    TweenService:Create(orbStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(255,80,80)}):Play()
                    TweenService:Create(SlotStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(220,50,50)}):Play()

                    for _,cell in ipairs(slotCells) do
                        if cell.lbl.Text~="—" then
                            TweenService:Create(cell.lbl,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(255,60,60)}):Play()
                            TweenService:Create(cell.frame,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(60,0,0)}):Play()
                        end
                    end

                    local fFlash=Instance.new("Frame",KSG); fFlash.Size=UDim2.new(1,0,1,0); fFlash.BackgroundColor3=Color3.fromRGB(220,30,30); fFlash.BackgroundTransparency=0.65; fFlash.ZIndex=30
                    TweenService:Create(fFlash,TweenInfo.new(0.3),{BackgroundTransparency=1}):Play(); ScanDebris:AddItem(fFlash,0.7)
                    for i=1,8 do task.delay((i-1)*0.045,function() ScanCard.Position=UDim2.new(0.5,(i%2==0 and 10 or -10),0.5,60+(i%2==0 and 4 or -4)) end) end
                    task.delay(0.4,function() ScanCard.Position=UDim2.new(0.5,0,0.5,60) end)

                    task.wait(1.8)
                    for _,cell in ipairs(slotCells) do
                        TweenService:Create(cell.lbl,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(0,60,100)}):Play()
                        TweenService:Create(cell.frame,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(0,20,45)}):Play()
                    end
                    cardStroke.Color=Color3.fromRGB(0,200,255)
                    orbStroke.Color=Color3.fromRGB(80,220,255)
                    HiddenInput.Text=""; HiddenInput.TextEditable=true; VerifyBtn.Active=true
                    Status.Text="◈  Try again..."; Status.TextColor3=Color3.fromRGB(0,160,210)
                end
            end

            VerifyBtn.MouseButton1Click:Connect(doVerify)
            HiddenInput.FocusLost:Connect(function(enter) if enter then doVerify() end end)
            task.delay(0.6,function() pcall(function() HiddenInput:CaptureFocus() end) end)
        end)
    end
})

