        local HRP = GetHRP(); if not HRP then return end

        local BPos  = Ball.Position
        local HPos  = HRP.Position
        local Dist  = (HPos - BPos).Magnitude
        local tgt   = Ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        TrackParryHit(tgt)

        -- God Emergency with 80-100ms buffer baked in
        if P.GodEmergency and isTgt and not PremLobbyDidParry and Dist <= 3.2 then
            PremLobbyFire(Ball)
            return
        end

        if not isTgt then PremLobbyVelHistory = {}; return end
        if PremLobbyDidParry then return end
        if not Plr.Character or not Plr.Character:FindFirstChild("HumanoidRootPart") then
            PremLobbyDidParry = false; PremLobbyLastParriedBall = nil; return
        end

        local RawVel = GetVel(Ball)

        -- 4-frame weighted velocity smoothing
        -- Recent frames weighted heavier so direction changes register fast
        table.insert(PremLobbyVelHistory, RawVel)
        if #PremLobbyVelHistory > 4 then table.remove(PremLobbyVelHistory, 1) end
        local wx, wy, wz, wt = 0, 0, 0, 0
        local weights = {0.10, 0.20, 0.30, 0.40}
        for i, v in ipairs(PremLobbyVelHistory) do
            local w = weights[i] or 0.25
            wx = wx + v.X * w
            wy = wy + v.Y * w
            wz = wz + v.Z * w
            wt = wt + w
        end
        local Vel   = Vector3.new(wx/wt, wy/wt, wz/wt)
        local Speed = Vel.Magnitude

        AdaptPremCooldown(Speed)

        -- Closing direction gate — rejects balls moving away
        local toPlayer  = HPos - BPos
        local dotVal    = Vel:Dot(toPlayer.Unit)
        local isClosing = dotVal > -(Speed * 0.10)
        -- Hard reject: ball moving clearly away and not close
        if dotVal < -(Speed * 0.25) and Dist > 11 then return end
        -- Soft reject: ball barely approaching at long range
        if dotVal < 2.5 and Dist > 14 then return end

        -- Speed spike multiplier (5-frame history)
        table.insert(PremLobbySpeedHist, Speed)
        if #PremLobbySpeedHist > 8 then table.remove(PremLobbySpeedHist, 1) end

        local spikeMul = 1.0
        if #PremLobbySpeedHist >= 5 then
            local prev4 = PremLobbySpeedHist[#PremLobbySpeedHist - 4]
            if prev4 and prev4 > 1 then
                local ratio = Speed / prev4
                if     ratio > 2.2 then spikeMul = 1.28
                elseif ratio > 1.6 then spikeMul = 1.16
                elseif ratio > 1.25 then spikeMul = 1.07
                end
            end
        end

        -- S-Tier curve detection (occasional curves only so kept mild)
        local sTierActive = DetectSTierCurve and DetectSTierCurve() or false
        local sTierMul    = sTierActive and 1.10 or 1.0

        -- Dynamic hitbox designed for ~80-100ms early trigger across all speeds:
        -- Slow  (<80):   fires at ~12-13 studs  → 80ms at 150 st/s
        -- Medium(80-160): fires at ~13-15 studs → 90ms at ~145 st/s avg
        -- Fast (>160):   fires at ~15-18 studs  → 95ms at ~180 st/s
        local SPD_REF  = 240
        local HB_MIN   = 12.0   -- slow ball base
        local HB_MAX   = 18.0   -- fast ball base
        local t        = math.clamp(Speed / SPD_REF, 0, 1)
        -- Cubic ease gives more range at high speeds where you need it most
        local curveFn  = 1 - (1 - t)^3
        local dynamicHitbox = (HB_MIN + (HB_MAX - HB_MIN) * curveFn) * spikeMul * sTierMul

        -- Ping lead: 0.09s lead target (sits inside 80-100ms window)
        -- Capped per speed tier so slow balls don't over-trigger
        local pingScale = math.clamp(Speed / 120, 0.30, 1.0)
        local pingLead  = (PingRaw / 1000) * Speed * 0.58
        local pingCap   = Speed > 160 and 6.5 or Speed > 80 and 4.5 or 3.0
        pingLead = math.min(pingLead * pingScale, pingCap)
        local fireDist  = dynamicHitbox + pingLead

        -- Primary fire
        if isClosing and Dist <= fireDist then
            PremLobbyFire(Ball)
            return
        end

        -- Multi-frame extrapolation
        -- Straight shots: up to 5 frames
        -- Curved shots: +2 extra frames with slight direction blend
        if Speed > 40 and isClosing then
            local dt        = 1/60
            local baseFrames = Speed > 220 and 5 or Speed > 160 and 4 or Speed > 80 and 3 or 2
            local maxFrames  = baseFrames + (sTierActive and 2 or 0)

            for step = 1, maxFrames do
                local nextPos
                if sTierActive then
                    -- Mild curve blend: 5% per frame toward player direction
                    local curveFactor = 0.05 * step
                    local blendDir    = (Vel.Unit + toPlayer.Unit * curveFactor).Unit
                    nextPos = BPos + blendDir * Speed * (dt * step)
                else
                    nextPos = BPos + Vel * (dt * step)
                end
                local nextDist = (HPos - nextPos).Magnitude
                if nextDist <= fireDist then
                    PremLobbyFire(Ball)
                    return
                end
            end
        end
    end)
end
