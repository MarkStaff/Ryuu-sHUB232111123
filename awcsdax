end

local function StartPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}
    posHist={}; speedHist={}; posHistQuad={}
    local lastVelDir = Vector3.zero

    -- Direction reversal: re-arm instantly when ball redirects
    PremiumConn.DirWatch = RunService.Heartbeat:Connect(function()
        local b = GetBall(); if not b then return end
        local v = GetVel(b)
        if v.Magnitude > 2 and lastVelDir.Magnitude > 0 then
            if v.Unit:Dot(lastVelDir.Unit) < -0.20 then
                S.DidParry = false
            end
        end
        if v.Magnitude > 0.5 then lastVelDir = v end
    end)

    PremiumConn.Parry = RunService.PreSimulation:Connect(function()
        local Ball = GetBall()
        if not Ball then posHist={}; speedHist={}; posHistQuad={}; return end
        local HRP = GetHRP(); if not HRP then return end
        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local Vel  = GetVel(Ball)
        local Speed = Vel.Magnitude
        local now  = os.clock()
        local isTgt = Ball:GetAttribute("target") == Plr.Name

        -- Auto-face
        if P.AutoFace and isTgt then
            pcall(function()
                HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X,HPos.Y,BPos.Z))
            end)
        end

        -- Emergency (only when targeted)
        if not S.DidParry and isTgt then
            local eDist = P.GodEmergency and 3.5 or S.EmergencyDist
            if Dist <= eDist then PremiumFire(); posHist={}; return end
        end

        if not isTgt then posHist={}; speedHist={}; posHistQuad={}; return end
        if S.DidParry then return end

        -- History tracking
        pushHist(Dist, now)
        pushQuadHist(BPos, now)
        table.insert(speedHist, Speed)
        if #speedHist > 8 then table.remove(speedHist, 1) end

        -- Stationary/slow ball: tight window
        if Speed < 1 then
            if Dist <= 11.5 then PremiumFire() end
            return
        end

        -- ANTI PRE-CLICK: must be closing (compare last 2 dist entries)
        if #posHist >= 2 then
            local prevDist = posHist[#posHist - 1].d
            if Dist >= prevDist - 0.005 then return end
        end

        -- ── Effective speed with ultra-high velocity detection ──
        local effectiveSpeed = Speed
        if #speedHist >= 3 then
            local oldest = speedHist[1]
            -- Standard boost (ability-triggered)
            if P.SpeedBoostDetect and oldest > 0 and Speed / oldest > 1.15 then
                effectiveSpeed = Speed * 1.20
            end
            -- ULTRA HIGH VELOCITY: ball moving insanely fast (>180 studs/s)
            -- Pre-compensate heavily so we don't miss it entirely
            if Speed > 180 then
                effectiveSpeed = Speed * 1.35
            elseif Speed > 120 then
                effectiveSpeed = Speed * 1.25
            elseif Speed > 80 then
                effectiveSpeed = Speed * 1.15
            end
        end

        -- ── Ping compensation ──
        local ping = PingAdapt.min
        local pingFactor = ping <= 60  and 1.1
            or ping <= 100 and (1.1 + (ping-60)/40 * 0.35)  -- 1.1→1.45 for 60-100ms
            or (1.45 + ((ping-100)/100) * 0.4)               -- 1.45→1.85 for 100-200ms
        pingFactor = math.min(pingFactor, 2.8)
        local pingComp = (ping / 1000) * effectiveSpeed * pingFactor

        -- ── Hitbox: base raised, speed-scaled, hard capped ──
        local baseHbox = P.HitboxTarget or 11.5
        local speedScalar = math.min(Speed / 60, 1.8)
        local hbox = baseHbox * (1 + speedScalar * 0.05)
        local fireAt = math.min(hbox + pingComp, 14.2)

        -- Core distance check
        if Dist <= fireAt then PremiumFire(); return end

        -- ── Lookahead: 5-frame quadratic prediction ──
        local nextPos  = predictQuadPos(BPos, Vel, 5/60)
        local nextDist = (HPos - nextPos).Magnitude
        if nextDist <= fireAt then PremiumFire(); return end

        -- ── Curve Crusher: weighted closing speed ──
        if P.CurveCrusher or S.AntiCurve then
            local sc = smoothClosing(Dist, now)
            if sc > 1.2 then
                local curveAt = hbox + (ping / 1000) * sc * 1.1
                if Dist <= curveAt then PremiumFire(); return end
            end
        end

        -- ── Quad curve prediction (premium flag) ──
        if P.QuadCurvePredict then
            local predPos  = predictQuadPos(BPos, Vel, 1/15)
            local predDist = (HPos - predPos).Magnitude
            if predDist <= fireAt then PremiumFire(); return end
        end
    end)
end

local function StopPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}
    S.DidParry = false
    speedHist = {}
    posHist = {}
    posHistQuad = {}
end
