                    {BackgroundColor3=Color3.fromRGB(28,5,5)}):Play()
                TweenService:Create(KInputStroke,TweenInfo.new(0.18),
                    {Color=Color3.fromRGB(200,40,40)}):Play()
                -- Red dot wave
                for i,d in ipairs(kDots) do
                    task.delay((i-1)*0.045,function()
                        pcall(function() d.BackgroundColor3=Color3.fromRGB(220,40,40); d.BackgroundTransparency=0 end)
                    end)
                end
                -- Red pulse
                TweenService:Create(KCStroke,TweenInfo.new(0.1),
                    {Color=Color3.fromRGB(255,80,80),Thickness=3.5}):Play()
                task.wait(0.12)
                TweenService:Create(KCStroke,TweenInfo.new(0.45),
                    {Color=Color3.fromRGB(180,35,35),Thickness=1.8}):Play()

                -- Red screen flash
                local RFlash=Instance.new("Frame",KSG)
                RFlash.Size=UDim2.new(1,0,1,0); RFlash.BackgroundColor3=Color3.fromRGB(200,30,30)
                RFlash.BackgroundTransparency=0.6; RFlash.BorderSizePixel=0; RFlash.ZIndex=998
                TweenService:Create(RFlash,TweenInfo.new(0.2),{BackgroundTransparency=0.15}):Play()
                task.wait(0.22)
                TweenService:Create(RFlash,TweenInfo.new(0.45,Enum.EasingStyle.Quad),
                    {BackgroundTransparency=1}):Play()
                playSound(6042053626, 0.6, 0.7)

                -- Shake card
                task.spawn(function()
                    for i=1,6 do
                        local ox=(i%2==0) and 5 or -5
                        pcall(function() KCard.Position=UDim2.new(0.5,ox,0.5,0) end)
                        task.wait(0.045)
                    end
                    pcall(function() KCard.Position=UDim2.new(0.5,0,0.5,0) end)
                end)

                -- Re-enable after delay
                task.wait(1.3)
                KInput.Text=""; KInput.TextEditable=true; KBtn.Active=true
                KTitle.Text="🔑  PREMIUM KEY SCANNER"; KTitle.TextColor3=Color3.fromRGB(0,210,255)
                KStatus.Text="Try again..."; KStatus.TextColor3=Color3.fromRGB(0,120,170)
                KCStroke.Color=Color3.fromRGB(0,210,255); KCStroke.Thickness=1.8
                KAccent.BackgroundColor3=Color3.fromRGB(0,210,255)
                -- Re-start dots
                dotsActive=true
                task.spawn(function()
                    local f=0
                    while dotsActive do
                        f=f+1
                        for i,d in ipairs(kDots) do
                            local on=(f%#kDots)==(i-1)
                            pcall(function()
                                d.BackgroundColor3=on and Color3.fromRGB(0,200,255) or Color3.fromRGB(0,40,80)
                                d.BackgroundTransparency=on and 0 or 0.5
                            end)
                        end
                        task.wait(0.07)
                    end
                end)
            end
        end

        KBtn.MouseButton1Click:Connect(doScan)
        KInput.FocusLost:Connect(function(enter) if enter then doScan() end end)
    end)
end})

