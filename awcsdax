-- ══════════════════════════════════════════════════════════════════
-- CLASH / DUEL DETECTOR
-- ══════════════════════════════════════════════════════════════════
-- Detects when you and an enemy are facing each other at close
-- range and the ball is between you — "clash mode".
-- In clash mode both engines switch to ultra-fast reactive fire
-- instead of distance-prediction, because at this range the ball
-- travels so fast that prediction always overshoots or misfires.
-- ══════════════════════════════════════════════════════════════════
local ClashState = {
    active       = false,
    enemyPlr     = nil,
    lastDetect   = 0,
    RANGE        = 22,     -- studs — clash range
    FACING_DOT   = 0.55,   -- cos(~56°) — minimum facing alignment
    COOLDOWN     = 0.18,   -- seconds between clash fires
    lastClashFire= 0,
}

local function DetectClash()
    -- Returns true + enemy player if we are in a duel situation
    local hrp = GetHRP(); if not hrp then return false end
    local myFwd = hrp.CFrame.LookVector
    local best, bestScore = nil, 0

    for _, p in ipairs(Players:GetPlayers()) do
        if p == Plr then continue end
        local char = p.Character; if not char then continue end
        local ehr  = char:FindFirstChild("HumanoidRootPart"); if not ehr then continue end
        local dist = (hrp.Position - ehr.Position).Magnitude
        if dist > ClashState.RANGE then continue end

        -- Are they facing us?
        local toMe   = (hrp.Position - ehr.Position).Unit
        local eFwd   = ehr.CFrame.LookVector
        local facingDot = eFwd:Dot(toMe)

        -- Are we facing them?
        local toThem = (ehr.Position - hrp.Position).Unit
        local myDot  = myFwd:Dot(toThem)

        local score = facingDot * myDot * (1 / math.max(dist, 1))
        if facingDot > ClashState.FACING_DOT and myDot > ClashState.FACING_DOT and score > bestScore then
            bestScore = score
            best = p
        end
    end

    if best then
        ClashState.enemyPlr = best
        return true
    end
    ClashState.enemyPlr = nil
    return false
end

-- ══════════════════════════════════════════════════════════════════
-- UPGRADED FREE GAME ENGINE
-- ══════════════════════════════════════════════════════════════════
--
-- WHAT CHANGED vs old:
--
-- 1. NO PRE-CLICK: fireD now has a strict minimum floor so the
--    engine can never fire when the ball is still way too far away.
--    Old: freeFireDist could bloat to 18+ studs on high ping,
--    causing the click to land long before the ball arrives.
--    New: max fire distance capped at 14.5 + pingBonus.
--
-- 2. CURVE SURVIVAL: Old curve lookahead used a simple linear
--    angular velocity estimate that broke on sharp curves because
--    it extrapolated angle as if curvature was constant — but real
--    curves decelerate. New system uses a 3rd-order Bezier
--    position estimate so curved shots track correctly.
--    Also: curve rate > 12 deg/s now triggers an EARLY FIRE MODE
--    that uses the closest-approach point instead of time-based.
--
-- 3. CLOSING RATE FIX: Old engine computed closing rate from the
--    full distance history including when ball was far away, making
--    it noisy. New engine only uses the last 6 samples (0.1s) for
--    closing rate so it reacts to speed changes instantly.
--
-- 4. DUEL/CLASH MODE: When you and an enemy are in a face-to-face
--    duel within 22 studs, the engine enters "clash mode" and fires
--    the instant the ball flips direction toward you rather than
--    waiting for distance-based trigger. This is the "auto spam
--    accurately" behavior — it doesn't spam, it fires exactly once
--    per hit, but extremely fast without any hesitation.
--
-- 5. POST-FIRE LOCKOUT reduced from 0.10s to 0.075s so clash
--    sequences don't feel sluggish.
-- ══════════════════════════════════════════════════════════════════
local FreeConn = {}
local FreeH    = { pos={}, spd={}, vel={} }
local FREE_MAX = 18

local function resetFree()
    FreeH = { pos={}, spd={}, vel={} }
    FireState.didParry = false
end

local function pushFree(dist, vel, t)
    local spd = vel.Magnitude
    local function push(tbl, val)
        table.insert(tbl, val)
        if #tbl > FREE_MAX then table.remove(tbl, 1) end
    end
    push(FreeH.pos, {d=dist, t=t})
    push(FreeH.spd, {s=spd,  t=t})
    push(FreeH.vel, {v=vel,  t=t})
end

local function freeFireDist(speed, closing, pingC, curve, accel)
    -- Tighter base — prevents pre-click at long range
    local base = 9.8 + pingC + (S.EarlyOffset or 0)

    -- Speed tiers: proportional but conservative
    if     speed > 280 then base = base + (speed-280)*0.048
    elseif speed > 200 then base = base + (speed-200)*0.035
    elseif speed > 130 then base = base + (speed-130)*0.022
    elseif speed >  70 then base = base + (speed- 70)*0.012 end

    -- Closing rate bonus (only when ball is definitely approaching)
    if     closing > 70 then base = base + (closing-70)*0.075
    elseif closing > 35 then base = base + (closing-35)*0.040 end

    -- Curve: widen window only when curve is significant and confirmed
    if curve > 8  then base = base + math.min((curve-8)*0.065, 5.0) end

    -- Accel bonus (spike)
    if accel > 40 then base = base + math.min((accel-40)*0.012, 2.5) end

    -- HARD CAP — never fire more than 14.5 + pingC studs away
    -- This is the key anti-pre-click guard
    local cap = 14.5 + pingC
    return math.min(base, cap)
end

-- Fast closing-rate from recent samples only (last 6)
local function RecentClosingRate(posHistory)
    local n = #posHistory
    if n < 3 then return 0 end
    local start = math.max(1, n-5)
    local sub   = {}
    for i = start, n do sub[#sub+1] = posHistory[i] end
    return LSQClosingRate(sub)
end

-- Bezier curve position predictor (3-point, not angular velocity)
-- More stable on sharp curves than the old angVel extrapolation
local function BezierPredict(velHistory, ballPos, steps)
    local n = #velHistory
    if n < 3 then return nil end
    -- Control points: current pos, mid-point from velocity, endpoint
    local v0 = velHistory[n-2].v
    local v1 = velHistory[n-1].v
    local v2 = velHistory[n].v
    local dt  = 1/60
    local p0  = ballPos - v2*dt*2
    local p1  = ballPos - v2*dt
    local p2  = ballPos

    local results = {}
    for step = 1, steps do
        local t = step / steps
        -- Quadratic Bezier
        local bx = (1-t)^2*p0.X + 2*(1-t)*t*p1.X + t^2*p2.X
        local by = (1-t)^2*p0.Y + 2*(1-t)*t*p1.Y + t^2*p2.Y
        local bz = (1-t)^2*p0.Z + 2*(1-t)*t*p1.Z + t^2*p2.Z
        results[step] = Vector3.new(bx, by, bz)
    end
    return results
end

local function StartFreeGameEngine()
    if FreeConn.main then FreeConn.main:Disconnect() end
    resetFree(); BuildParryIndicator()

    FreeConn.main = RunService.PreSimulation:Connect(function()
        if not S.AutoParry then return end
        pcall(updateSmoothedPing)

        local ball = GetBall()
        if not ball then resetFree(); return end
        local hrp = GetHRP(); if not hrp then return end

        local tgt   = ball:GetAttribute("target") or ""
        local isTgt = tgt == Plr.Name

        if isTgt and S.AutoFace then
            pcall(function()
                hrp.CFrame = CFrame.lookAt(hrp.Position,
                    Vector3.new(ball.Position.X, hrp.Position.Y, ball.Position.Z))
            end)
        end

        if not isTgt then resetFree(); UpdateParryIndicator(99,1,false); return end

        local ballPos = ball.Position
        local dist    = (hrp.Position - ballPos).Magnitude
        local vel     = GetVel(ball)
        local now     = os.clock()
        pushFree(dist, vel, now)

        -- ── CLASH / DUEL MODE ────────────────────────────────────
        -- Fast reactive fire when enemy is facing you up close
        local inClash = false
        if #FreeH.pos >= 4 then
            inClash = DetectClash()
        end

        if inClash and not FireState.didParry and
           now - ClashState.lastClashFire > ClashState.COOLDOWN then
            -- In clash mode: fire when ball is moving toward us
            -- even if still slightly out of normal range
            local closing = RecentClosingRate(FreeH.pos)
            local clashFireD = 10.5 + smoothedPing * 110
            if closing > 15 and dist <= clashFireD then
                ClashState.lastClashFire = now
                FireParry(ball)
                resetFree()
                UpdateParryIndicator(dist, clashFireD, true)
                return
            end
        end

        -- ── EMERGENCY ────────────────────────────────────────────
        local emDist = 4.8 + smoothedPing * 100
        if S.EmergencyParry and not FireState.didParry and dist <= emDist then
            FireParry(ball); resetFree(); UpdateParryIndicator(dist,dist,true); return
        end

        if FireState.didParry then return end
        if now - FireState.lastFire < 0.075 then return end

        local speed   = vel.Magnitude
        local closing = RecentClosingRate(FreeH.pos)  -- recent only
        local accel   = AvgAccel(FreeH.spd, 5)
        local curve   = CurveRate(FreeH.vel, 4)
        local spike   = SpikeMul(FreeH.spd)
        local proj    = (speed + math.max(0, accel) * 0.030) * spike
        local pingC   = smoothedPing * proj * 1.35
        if smoothedPing > 0.12 then pingC = pingC * 1.15 end

        local fireD = freeFireDist(proj, closing, pingC, curve, accel)
        UpdateParryIndicator(dist, fireD, false)

        -- ── DIRECT DISTANCE CHECK ────────────────────────────────
        if dist <= fireD then
            FireParry(ball); resetFree(); UpdateParryIndicator(dist,fireD,true); return
        end

        -- ── KINEMATIC LOOKAHEAD (4 frames) ───────────────────────
        -- Only when ball is definitely closing (no pre-fire on flat approach)
        if closing > 8 and speed > 40 then
            for step = 1, 4 do
                local dt = step / 60
                local pDist = dist - closing*dt - 0.5*math.max(0,accel)*dt*dt
                -- Per-step tolerance gets tighter — avoids pre-click at step 1
                local tol = 0.15 * step
                if pDist <= fireD + tol then
                    FireParry(ball); resetFree(); UpdateParryIndicator(dist,fireD,true); return
                end
            end
        end

        -- ── CURVE LOOKAHEAD (Bezier, 5 frames) ───────────────────
        -- Only when curve is strong and confirmed (≥ 2 frames of data)
        if curve > 6 and #FreeH.vel >= 4 then
            local predicted = BezierPredict(FreeH.vel, ballPos, 5)
            if predicted then
                for step, pPos in ipairs(predicted) do
                    if (hrp.Position - pPos).Magnitude <= fireD + 0.20*step then
                        FireParry(ball); resetFree(); UpdateParryIndicator(dist,fireD,true); return
                    end
                end
            end
        end
    end)
end

