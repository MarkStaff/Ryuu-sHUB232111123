local function GetVel(ball)
    local best = Vector3.zero
    local ok1, v1 = pcall(function() return ball.AssemblyLinearVelocity end)
    if ok1 and v1.Magnitude > best.Magnitude then best = v1 end
    local ok2, v2 = pcall(function()
        local bv = ball:FindFirstChild("zoomies")
        return (bv and bv:IsA("BodyVelocity")) and bv.VectorVelocity or Vector3.zero
    end)
    if ok2 and v2.Magnitude > best.Magnitude then best = v2 end
    pcall(function()
        for _, d in ipairs(ball:GetChildren()) do
            if d:IsA("BodyVelocity") and d.VectorVelocity.Magnitude > best.Magnitude then
                best = d.VectorVelocity
            end
            if d:IsA("LinearVelocity") and d.VectorVelocity.Magnitude > best.Magnitude then
                best = d.VectorVelocity
            end
        end
    end)
    return best
end
