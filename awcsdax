-- PING SAMPLER
-- ══════════════════════════════════════════════════════════════════
local PingMs      = 1
local PingRaw     = 0
local PingBonus   = 0
local PingScale   = 1.0
local PingSamples = {}
local PingJitter  = 0

task.spawn(function()
    while true do
        local ok, raw = pcall(function()
            return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
        end)
        if ok and type(raw)=="number" and raw>0 then
            PingRaw = raw
            table.insert(PingSamples, raw)
            if #PingSamples>12 then table.remove(PingSamples,1) end
            local lowest = math.huge
            for _,v in ipairs(PingSamples) do
                if v < lowest then lowest = v end
            end
            PingMs = lowest
            if #PingSamples>=4 then
                local n = #PingSamples
                local recent = {PingSamples[n], PingSamples[n-1], PingSamples[n-2], PingSamples[n-3]}
                local jSum=0; for _,v in ipairs(recent) do jSum=jSum+v end
                local jMean=jSum/4
                local jDev=0; for _,v in ipairs(recent) do jDev=jDev+math.abs(v-jMean) end
                PingJitter = jDev/4
            end
            PingBonus = (PingMs/1000) * PingScale
        end
        task.wait(0.5)
    end
end)

