-- Manual drag (no Draggable = true — it causes 2-second input delay/acceleration)
do
    local dragging, dragStart, startPos = false, nil, nil
    MSCard.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = inp.Position
            startPos  = MSCard.Position
        end
    end)
    MSCard.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
            or inp.UserInputType == Enum.UserInputType.Touch) then
            local delta = inp.Position - dragStart
            local np = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
            MSCard.Position   = np
            MSShadow.Position = UDim2.new(np.X.Scale, np.X.Offset+4, np.Y.Scale, np.Y.Offset+4)
        end
    end)
    MSCard.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

