local function RefreshBB(plr)
    if not (plr and plr.Character) then return end
    local bb = AbilityBBs[plr]
    if not (bb and bb.Parent) then BuildAbilityBB(plr); bb=AbilityBBs[plr] end
    if not bb then return end
    local bg = bb:FindFirstChildOfClass("Frame"); if not bg then return end
    local aLbl = bg:FindFirstChild("AN")
    local badge = bg:FindFirstChild("TB")
    local stk = bg:FindFirstChildOfClass("UIStroke")
    if not aLbl then return end
    local name = ScanAbility(plr)
    -- DIRTY FLAG: skip redraw if ability hasn't changed (kills FPS drop)
    local cacheKey = name or "__none__"
    if AbilityLastSeen[plr] == cacheKey then return end
    AbilityLastSeen[plr] = cacheKey
    if name then
        local data = BB_ABILITIES[name]
        if data then
            local col = data.warn and Color3.fromRGB(255,70,70) or data.col
            aLbl.Text = (data.warn and "⚠ " or "")..name
            aLbl.TextColor3 = col
            if badge then badge.Text = data.tier
                          badge.TextColor3 = TIER_COL[data.tier] or Color3.fromRGB(180,100,255) end
            if stk then stk.Color = data.warn and Color3.fromRGB(200,50,50) or data.col end
        else
            aLbl.Text = name
            aLbl.TextColor3 = Color3.fromRGB(200,200,200)
            if badge then badge.Text = "?" end
            if stk then stk.Color = Color3.fromRGB(50,25,90) end
        end
    else
        aLbl.Text = "No Ability"
        aLbl.TextColor3 = Color3.fromRGB(90,85,110)
        if badge then badge.Text = "-" end
        if stk then stk.Color = Color3.fromRGB(30,15,50) end
    end
end
local function CleanAbilityESP()
    if AbilityPoll then AbilityPoll:Disconnect(); AbilityPoll=nil end
    for _, bb in pairs(AbilityBBs) do
        pcall(function() if bb and bb.Parent then bb:Destroy() end end)
    end
    AbilityBBs = {}
end
local function StartAbilityESP()
    CleanAbilityESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Plr then
            BuildAbilityBB(p)
            RefreshBB(p)
        end
    end
    task.spawn(function()
        while S.AbilityESP do
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Plr then
                    if p.Character then
                        local head = p.Character:FindFirstChild("Head")
                        if head then
                            local bb = AbilityBBs[p]
                            if not bb or not bb.Parent or bb.Parent ~= head then
                                BuildAbilityBB(p)
                            end
                            RefreshBB(p)
                        end
                    end
                end
            end
            for p, bb in pairs(AbilityBBs) do
                if not p.Parent then
                    pcall(function() if bb and bb.Parent then bb:Destroy() end end)
                    AbilityBBs[p] = nil
                end
            end
            task.wait(0.8)  -- slowed from 0.4 -- dirty cache means no visual difference
        end
    end)
    Players.PlayerAdded:Connect(function(p)
        if not S.AbilityESP then return end
        p.CharacterAdded:Connect(function()
            task.wait(0.5)
            if S.AbilityESP then BuildAbilityBB(p); RefreshBB(p) end
        end)
    end)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Plr then
            p.CharacterAdded:Connect(function()
                task.wait(0.5)
                if S.AbilityESP then BuildAbilityBB(p); RefreshBB(p) end
            end)
        end
    end
end
