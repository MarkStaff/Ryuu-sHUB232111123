    Ring2Stroke.Color = Color3.fromRGB(255,160,255)
    task.wait(0.08)
    TweenService:Create(Ring2, TweenInfo.new(0.55, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Size = UDim2.new(0,380,0,380)}):Play()
    TweenService:Create(Ring2Stroke, TweenInfo.new(0.55, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        {Transparency = 1}):Play()

    -- Purple orb bursts then disappears
    local Orb = Instance.new("Frame", AnimSG)
    Orb.AnchorPoint = Vector2.new(0.5,0.5)
    Orb.Position = UDim2.new(0.5,0,0.5,0)
    Orb.Size = UDim2.new(0,0,0,0)
    Orb.BackgroundColor3 = Color3.fromRGB(180,80,255)
    Orb.BackgroundTransparency = 0.3
    Orb.BorderSizePixel = 0
    Orb.ZIndex = 3
    Instance.new("UICorner", Orb).CornerRadius = UDim.new(1,0)
    local OrbGrad = Instance.new("UIGradient", Orb)
    OrbGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255,200,255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(180,80,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(60,10,120)),
