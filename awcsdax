    ["Cyan"] = Color3.fromRGB( 0, 220, 220),
    ["Orange"] = Color3.fromRGB(255, 120, 20),
    ["Rainbow"] = nil,
}
local SWORD_MATERIALS = {
    ["Default"] = Enum.Material.SmoothPlastic,
    ["Neon Purple"] = Enum.Material.Neon,
    ["Emerald"] = Enum.Material.Neon,
    ["Cyan"] = Enum.Material.Neon,
    ["Rainbow"] = Enum.Material.Neon,
}
local CurrentSwordPreset = "Default"
local SwordOrigColors = {}
local RainbowHue = 0
local function GetSwordParts()
    local char = Plr.Character; if not char then return nil, {} end
    local tool = nil
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") then tool = v; break end
    end
    if not tool then return nil, {} end
    local parts = {}
    for _, v in ipairs(tool:GetDescendants()) do
        if v:IsA("BasePart") or v:IsA("UnionOperation") then
            parts[#parts+1] = v
        end
    end
    local h = tool:FindFirstChild("Handle")
    if h then parts[#parts+1] = h end
    return tool, parts
end
local function SaveSwordOriginals(parts)
    for _, p in ipairs(parts) do
        if not SwordOrigColors[p] then
            SwordOrigColors[p] = {color=p.Color, mat=p.Material}
        end
    end
end
local function ApplySwordPreset(presetName)
    CurrentSwordPreset = presetName
    local _, parts = GetSwordParts()
    if #parts == 0 then return end
    SaveSwordOriginals(parts)
    local mat = SWORD_MATERIALS[presetName] or Enum.Material.SmoothPlastic
    if presetName == "Default" then
        for _, p in ipairs(parts) do
            local orig = SwordOrigColors[p]
            if orig then
                pcall(function() p.Color = orig.color; p.Material = orig.mat end)
            end
        end
        return
    end
    if presetName == "Rainbow" then
        RainbowHue = (RainbowHue + 0.08) % 1
        local col = Color3.fromHSV(RainbowHue, 1, 1)
        for _, p in ipairs(parts) do
            pcall(function() p.Color = col; p.Material = Enum.Material.Neon end)
        end
        return
    end
    local col = SWORD_COLORS[presetName]
    if not col then return end
    for _, p in ipairs(parts) do
        pcall(function() p.Color = col; p.Material = mat end)
    end
end
