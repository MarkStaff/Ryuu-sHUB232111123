        local spikeMul = 1.0
        if #LobbyFreeSpeedHist >= 4 then
            local prev = LobbyFreeSpeedHist[#LobbyFreeSpeedHist - 3]
            if prev and prev > 1 then
                local ratio = Speed / prev
                if     ratio > 2.0 then spikeMul = 1.28
                elseif ratio > 1.5 then spikeMul = 1.16
                elseif ratio > 1.2 then spikeMul = 1.06
                end
            end
        end

        -- Dynamic hitbox: larger base so shield animation triggers in time
        local SPD_REF      = 260
        local HB_MIN       = 11.5
        local HB_MAX       = 17.5
        local t            = math.clamp(Speed / SPD_REF, 0, 1)
        local curve        = t < 0.5 and (2*t*t) or (1-(-2*t+2)^2/2)
        local dynamicHitbox = (HB_MIN + (HB_MAX - HB_MIN) * curve) * spikeMul

        -- Ping lead tuned for shield anim window
        local pingScale = math.clamp(Speed / 100, 0.4, 1.0)
        local pingLead  = (PingRaw / 1000) * Speed * 0.60
        pingLead = math.min(pingLead * pingScale, 6.5)
        local fireDist  = dynamicHitbox + pingLead

        if isClosing and Dist <= fireDist then
            LobbyFireParry(Ball)
            return
        end

        -- Multi-frame extrapolation
        if Speed > 50 and isClosing then
            local dt        = 1/60
            local maxFrames = Speed > 220 and 5 or Speed > 160 and 4 or Speed > 100 and 3 or 2
            for step = 1, maxFrames do
                local nextPos  = BPos + Vel * (dt * step)
                local nextDist = (HPos - nextPos).Magnitude
                if nextDist <= fireDist then
                    LobbyFireParry(Ball)
                    return
                end
            end
        end
    end)
end
