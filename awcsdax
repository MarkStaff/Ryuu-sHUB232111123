-- ══════════════════════════════════════════════════════════════════
--   KEY SYSTEM  ◈  Device-locked keys
--
--   Add keys to VALID_KEYS below. Each key can only ever be used
--   on ONE device. The moment someone unlocks with a key, that key
--   is permanently bound to their device. Anyone else who tries the
--   same key on a different device gets rejected.
--
--   How it works:
--   • A unique device ID is generated on first run and saved to
--     ryuu_device.txt on the executor's file system.
--   • When a key is used, we save {key → deviceID} to ryuu_keys.txt.
--   • Every future attempt checks: does this key's stored deviceID
--     match the current device? If not → rejected.
--
--   To revoke a key: remove it from VALID_KEYS. Done.
--   Make keys hard to guess: "RYUU-X9K2-M3P7-BLADE"
-- ══════════════════════════════════════════════════════════════════
local VALID_KEYS = {
    "RYUU-KEY1-CHANGEME",
    "RYUU-KEY2-CHANGEME",
    "RYUU-KEY3-CHANGEME",
}
local IsWhitelisted = false
local PremiumActive = false

-- ── Device ID ─────────────────────────────────────────────────────
-- Generated once, stored forever. This is what locks the key to the device.
local DEVICE_FILE = "ryuu_device.txt"
local LOCK_FILE   = "ryuu_keys.txt"   -- stores key→deviceID pairs

local function GetDeviceID()
    -- Try to read existing device ID
    local ok, stored = pcall(function() return readfile(DEVICE_FILE) end)
    if ok and stored and #stored >= 16 then
        return stored:match("^%s*(.-)%s*$")
    end
    -- Generate a new one from stable sources
    local parts = {}
    -- Use Roblox client analytics ID if available
    pcall(function()
        local id = tostring(game:GetService("RbxAnalyticsService"):GetClientId())
        if id and #id > 4 then table.insert(parts, id) end
    end)
    -- Add local player ID as extra salt
    pcall(function() table.insert(parts, tostring(Plr.UserId)) end)
    -- Add a random component so even same-user different-PC gets different ID
    table.insert(parts, tostring(math.random(100000, 999999)))
    table.insert(parts, tostring(os.time()))
    local raw = table.concat(parts, "-")
    -- Hash it into a clean 24-char ID
    local hash = 0
    for i = 1, #raw do
        hash = (hash * 31 + string.byte(raw, i)) % 0xFFFFFFFF
    end
    local deviceID = string.format("DEV-%08X-%08X-%06d",
        hash,
        (hash * 1000003) % 0xFFFFFFFF,
        math.random(100000, 999999)
    )
    -- Save it
    pcall(function() writefile(DEVICE_FILE, deviceID) end)
    return deviceID
end

local function LoadLocks()
    -- Returns table: {[key] = deviceID}
    local ok, data = pcall(function() return readfile(LOCK_FILE) end)
    if not ok or not data or data == "" then return {} end
    local locks = {}
    for line in data:gmatch("[^\n]+") do
        local k, d = line:match("^(.+)=(.+)$")
        if k and d then locks[k] = d end
    end
    return locks
end

local function SaveLocks(locks)
    local lines = {}
    for k, d in pairs(locks) do
        table.insert(lines, k .. "=" .. d)
    end
    pcall(function() writefile(LOCK_FILE, table.concat(lines, "\n")) end)
end

-- Returns: "ok", "invalid", "locked_other"
local function ValidateKey(key)
    if not key or #key < 4 then return "invalid" end
    local k = key:match("^%s*(.-)%s*$")

    -- Check key exists in valid list
    local keyExists = false
    for _, v in ipairs(VALID_KEYS) do
        if v == k then keyExists = true; break end
    end
    if not keyExists then return "invalid" end

    -- Get this device's ID
    local myDevice = GetDeviceID()

    -- Check lock file
    local locks = LoadLocks()

    if locks[k] == nil then
        -- First use — lock it to this device NOW
        locks[k] = myDevice
        SaveLocks(locks)
        return "ok"
    elseif locks[k] == myDevice then
        -- Same device that originally used it — allow
        return "ok"
    else
        -- Different device — reject
        return "locked_other"
    end
end

