-- PARRY STATS  ◈  Success rate tracker + HUD integration
-- ══════════════════════════════════════════════════════════════════
local ParryStats = {
    total          = 0,
    hits           = 0,
    lastBallTarget = "",
    lastFireTime   = 0,
}

local function TrackParryHit(ballTarget)
    -- Ball stopped targeting us within 0.4s of a parry = confirmed hit
    if ballTarget ~= Plr.Name and ParryStats.lastBallTarget == Plr.Name then
        if os.clock() - ParryStats.lastFireTime < 0.4 then
            ParryStats.hits = ParryStats.hits + 1
        end
    end
    ParryStats.lastBallTarget = ballTarget or ""
end

local function ParrySuccessRate()
    if ParryStats.total == 0 then return 100 end
    return math.floor((ParryStats.hits / ParryStats.total) * 100)
end

-- ══════════════════════════════════════════════════════════════════
-- PARRY FIRE HELPERS  ◈  Anti-stagger + accurate hit tracking
-- ══════════════════════════════════════════════════════════════════

-- Anti-stagger: track the exact ball instance last parried — never double-fire same ball
local FreeLastParriedBall = nil
local PremLastParriedBall = nil

-- Anti-spam: tracks last fire time and suppresses rapid duplicate fires
-- Prevents double-click spam and engine looping on the same close-range ball
local FREE_ANTI_SPAM_CD = 0.08  -- minimum 80ms between any two free fires

local function FireParry(ball)
    if S.DidParry then return end
    if os.clock() - S.LastParry < S.ParryCooldown then return end
    if os.clock() - S.LastParry < FREE_ANTI_SPAM_CD then return end  -- anti-spam gate
    if ball and ball == FreeLastParriedBall then return end  -- anti-stagger

    VIM:SendMouseButtonEvent(0,0,0,true,  game, 0)
    S.LastParry             = os.clock()
    S.DidParry              = true
    S.ParryCount            = S.ParryCount + 1
    ParryStats.total        = ParryStats.total + 1
    ParryStats.lastFireTime = os.clock()
    FreeLastParriedBall     = ball

    task.spawn(function()
        task.wait(0.015)
        VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
    end)
    task.delay(S.ParryReset or 0.16, function()
        S.DidParry          = false
        FreeLastParriedBall = nil
    end)
end

-- Premium adaptive cooldown — shrinks when ball is fast, grows when slow
local PremCooldown      = 0.15
local PremCooldownBase  = 0.15   -- floor
local PremCooldownMax   = 0.22   -- ceiling
local PremLastParry     = 0
local PremDidParry      = false

local PremConn = {}  -- connection table for premium engine (shared scope)
local PremSpeedWarnThreshold = 160
local PremLastSpeedWarn      = 0

local function AdaptPremCooldown(speed)
    -- Fast ball = tighter cooldown, slow ball = looser
    if     speed > 200 then PremCooldown = PremCooldownBase
    elseif speed > 140 then PremCooldown = PremCooldownBase + 0.02
    elseif speed >  80 then PremCooldown = PremCooldownBase + 0.04
    else                    PremCooldown = PremCooldownMax
    end
end

local function CheckBallSpeedWarning(speed)
    if not PremiumUnlocked then return end
    local now = os.clock()
    if speed >= PremSpeedWarnThreshold and now - PremLastSpeedWarn > 2.5 then
        PremLastSpeedWarn = now
        -- notification removed (caused frame drops)
    end
end

local function PremiumFire(ball)
    local now = os.clock()
    if PremDidParry then return end
    if now - PremLastParry < PremCooldown then return end
    if ball and ball == PremLastParriedBall then return end  -- anti-stagger

    VIM:SendMouseButtonEvent(0,0,0,true,  game, 0)
    PremLastParry           = now
    PremDidParry            = true
    S.ParryCount            = S.ParryCount + 1
    ParryStats.total        = ParryStats.total + 1
    ParryStats.lastFireTime = now
    PremLastParriedBall     = ball

    task.spawn(function()
        task.wait(0.015)
        VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
    end)
    task.delay(PremCooldown * 0.70, function()
        PremDidParry        = false
        PremLastParriedBall = nil
    end)
end

