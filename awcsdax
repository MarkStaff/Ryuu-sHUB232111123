        if P.GodEmergency and isTgt and not PremFire.didParry and Dist <= godDist then
            PremiumFire(Ball)
            resetPremHistory()
            UpdateParryIndicator(Dist, Dist, true)
            return
        end

        if not isTgt then
            resetPremHistory()
            UpdateParryIndicator(99, 1, false)
            return
        end
        if PremFire.didParry then return end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        pushPremHist(Dist, Vel, os.clock())

        local acc = premAccel()
        local curveRate = premCurveRate()
        local closingRate = premLSQRate()
        local projSpeed = (Speed + math.max(0, acc) * 0.035) * premSpikeMul()
        local pingComp = smoothedPing * projSpeed * 1.45
        if smoothedPing > 0.14 then pingComp *= 1.18 end

        local fireDist = premFireDist(projSpeed, closingRate, pingComp, curveRate, P.HitboxTarget)

        UpdateParryIndicator(Dist, fireDist, false)

        if Dist <= fireDist then
            PremiumFire(Ball)
            resetPremHistory()
            UpdateParryIndicator(Dist, fireDist, true)
            return
        end
    end)
end

