}

-- Ability icon image IDs. 0 = no image yet, shows tier letter fallback.
-- The auto-scanner below tries to find real IDs from the game at runtime.
local ABILITY_IMAGES = {
    ["Infinity"]=0,["Time Hole"]=0,["Slash of Duality"]=0,["Dribble"]=0,
    ["Dragon Spirit"]=0,["Pull"]=0,["Guardian Angel"]=0,["Reaper"]=0,
