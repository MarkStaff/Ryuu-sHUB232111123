-- ── 8. AUTO DODGE ────────────────────────────────────────────────
-- When the ball is targeting YOU and within a threshold,
-- fires a random strafe direction to break the ball's path.
-- Uses BodyVelocity for a clean instant burst.
local AutoDodge = {conn=nil, cd=0}
local function StartAutoDodge()
    if AutoDodge.conn then AutoDodge.conn:Disconnect() end
    AutoDodge.conn = RunService.Heartbeat:Connect(function()
        pcall(function()
            if not PremiumUnlocked then return end
            local ball = GetBall(); if not ball then return end
            local hrp = GetHRP(); if not hrp then return end
            if ball:GetAttribute("target") ~= Plr.Name then return end
            local dist = (hrp.Position - ball.Position).Magnitude
            local now = os.clock()
            if dist <= 18 and now - AutoDodge.cd > 1.2 then
                AutoDodge.cd = now
                local dirs = {
                    hrp.CFrame.RightVector,
                    -hrp.CFrame.RightVector,
                    hrp.CFrame.RightVector + hrp.CFrame.LookVector,
                    -hrp.CFrame.RightVector - hrp.CFrame.LookVector,
                }
                local dir = dirs[math.random(1, #dirs)]
                local bv = Instance.new("BodyVelocity", hrp)
                bv.Velocity = dir * 55
                bv.MaxForce = Vector3.new(1e5, 0, 1e5)
                game:GetService("Debris"):AddItem(bv, 0.12)
            end
        end)
    end)
end
local function StopAutoDodge()
    if AutoDodge.conn then AutoDodge.conn:Disconnect(); AutoDodge.conn = nil end
end

