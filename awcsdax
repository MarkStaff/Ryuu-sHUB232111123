    ["Continuity Zero"]=0,["Death Slash"]=0,["Phantom"]=0,["Swap"]=0,
    ["Doppelganger"]=0,["Necromancer"]=0,["Serpent Shadow Clone"]=0,
    ["Phase Bypass"]=0,["Hell Hook"]=0,["Blink"]=0,["Qi-Charge"]=0,
    ["Telekinesis"]=0,["Aerodynamic Slash"]=0,["Rapture"]=0,
