local PrevBallPos = nil
local PrevBallTime = 0

local function FireParry()
    if S.DidParry then return end
    if os.clock() - S.LastParry < S.ParryCooldown then return end
    VIM:SendMouseButtonEvent(0,0,0,true, game, 0)
    S.LastParry = os.clock()
    S.DidParry = true
    S.ParryCount = S.ParryCount + 1
    local rc
    rc = RunService.Heartbeat:Connect(function()
        VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
        rc:Disconnect()
    end)
    task.delay(S.ParryCooldown, function() S.DidParry = false end)
end

local function StartEngine()
    if Conn.Parry then Conn.Parry:Disconnect(); Conn.Parry=nil end
    if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
    if Conn.BallAdded then Conn.BallAdded:Disconnect(); Conn.BallAdded=nil end
    if Conn.DirWatch then Conn.DirWatch:Disconnect(); Conn.DirWatch=nil end
    S.DidParry = false
    PrevBallPos = nil

    local function HookBall(ball)
        if not ball then return end
        if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
        Conn.Target = ball:GetAttributeChangedSignal("target"):Connect(function()
            S.DidParry = false
        end)
    end
    HookBall(GetBall())

    local function hookFolder(folder)
        if not folder then return end
        Conn.BallAdded = folder.ChildAdded:Connect(function()
            task.wait(0.05)
            local b = GetBall()
            if b then S.DidParry=false; PrevBallPos=nil; HookBall(b) end
        end)
    end
    local bf = workspace:FindFirstChild("Balls")
    if bf then hookFolder(bf)
    else task.spawn(function()
        local f = workspace:WaitForChild("Balls", 30)
        if f and not Conn.BallAdded then hookFolder(f) end
    end) end

    -- Direction reversal watcher: resets DidParry when ball bounces back
    local lastDir = Vector3.zero
    Conn.DirWatch = RunService.Heartbeat:Connect(function()
        if not S.AutoParry then return end
        local b = GetBall(); if not b then return end
        local v = GetVel(b)
        if v.Magnitude > 2 and lastDir.Magnitude > 0 then
            if v.Unit:Dot(lastDir.Unit) < -0.4 then
                S.DidParry = false
            end
        end
        if v.Magnitude > 0.5 then lastDir = v end
    end)

    Conn.Parry = RunService.PreSimulation:Connect(function()
        if not S.AutoParry then return end
        local Ball = GetBall()
        if not Ball then PrevBallPos=nil; return end
        local HRP = GetHRP()
        if not HRP then return end

        local BPos = Ball.Position
        local HPos = HRP.Position
        local Dist = (HPos - BPos).Magnitude
        local now = os.clock()

        -- Emergency: fires regardless of isTgt for point-blank attacks
        if S.EmergencyParry and not S.DidParry then
            if Dist <= S.EmergencyDist then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= Plr and p.Character then
                        local ehr = p.Character:FindFirstChild("HumanoidRootPart")
                        if ehr and (ehr.Position - HPos).Magnitude <= (S.EmergencyDist + 10) then
                            FireParry(); break
                        end
                    end
                end
            end
        end

        local isTgt = Ball:GetAttribute("target") == Plr.Name
        if S.AutoFace and isTgt then
            HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X, HPos.Y, BPos.Z))
        end
        if not isTgt then PrevBallPos=nil; return end
        if S.DidParry then return end

        local Vel = GetVel(Ball)
        local Speed = Vel.Magnitude

        if Speed < 1 then
            if Dist <= 6 then FireParry() end
            return
        end

        -- ── CLEAN PARRY — simple, correct, never early, never late ──
        --
        -- Fire when:  Dist  <=  6  +  (PingMs/2000) * Speed
        --
        -- 6 studs    = server parry hitbox size (safe centre)
        -- PingMs/2000 = one-way ping in seconds
        -- * Speed    = studs the ball travels while click is in transit
        --
        -- Result: click always arrives when ball is exactly ~6 studs away.
        -- Works at any speed, any ping, any angle. No dot product, no TTI math.
        --
        -- AntiCurve: same formula but uses position-delta closing speed
        -- so curved balls that change velocity direction still get caught.

        local fireAt = 6 + (PingMs / 2000) * Speed

        if Dist <= fireAt then
            FireParry()
            PrevBallPos  = BPos
            PrevBallTime = now
            return
        end

        -- AntiCurve: position-based closing speed catches curved balls
        if S.AntiCurve and PrevBallPos ~= nil then
            local dt = now - PrevBallTime
            if dt > 0.001 then
                local prevDist   = (HPos - PrevBallPos).Magnitude
                local posClosing = (prevDist - Dist) / dt
                if posClosing > 5 then
                    local curveFireAt = 6 + (PingMs / 2000) * posClosing
                    if Dist <= curveFireAt then
                        FireParry()
                    end
                end
            end
        end

        PrevBallPos = BPos
        PrevBallTime = now

        if S.Triggerbot and Dist <= 2 then FireParry() end
    end)
end

local function StopEngine()
    if Conn.Parry then Conn.Parry:Disconnect(); Conn.Parry=nil end
    if Conn.Target then Conn.Target:Disconnect(); Conn.Target=nil end
    if Conn.BallAdded then Conn.BallAdded:Disconnect(); Conn.BallAdded=nil end
    if Conn.DirWatch then Conn.DirWatch:Disconnect(); Conn.DirWatch=nil end
    S.DidParry=false; PrevBallPos=nil
end

-- ══════════════════════════════════════════════════════════════════
--   PREMIUM ENGINE  ◈  Aggressive fast parry for whitelisted users
-- ══════════════════════════════════════════════════════════════════
-- ══════════════════════════════════════════════════════════════════
--   PREMIUM ENGINE  ◈  Strictly better than free in every way
--
--   FREE  engine: fireAt = 6   + (PingMs/2000)*Speed   → lands at 6 studs
--   PREMIUM engine: fireAt = 4.5 + (PingMs/2000)*Speed → lands at 4.5 studs
--
--   Tighter hitbox = fires slightly later = more precise = never pre-clicks.
--   3 extra systems free doesn't have:
--     1. Velocity extrapolation — predicts ball next-frame position
--     2. Multi-frame curve history — 5-frame smoothed closing speed
--     3. Instant re-arm — detects ball direction reversal in <1 frame
-- ══════════════════════════════════════════════════════════════════
local PremiumConn = {}

-- Premium state
local P = {
    AutoParry        = false,
    GodEmergency     = false,   -- tighter emergency (3 studs vs free's 6)
    CurveCrusher     = false,   -- 5-frame smoothed anticurve
    AutoFace         = false,   -- always face ball
    HitboxTarget     = 4.5,     -- studs on server when click arrives (slider)
    SpeedBoostDetect = true,    -- auto-adjust for accelerating balls
}

-- Speed history for boost detection (3 frames)
local speedHist = {}

local function StartPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}

    -- Premium fire: faster mouse release than free (same-frame rc connect)
    local function PremiumFire()
        if S.DidParry then return end
        if os.clock() - S.LastParry < 0.20 then return end
        VIM:SendMouseButtonEvent(0,0,0,true, game, 0)
        S.LastParry  = os.clock()
        S.DidParry   = true
        S.ParryCount = S.ParryCount + 1
        -- Release on very next heartbeat — tighter than free's Heartbeat connect
        local rc
        rc = RunService.Heartbeat:Connect(function()
            VIM:SendMouseButtonEvent(0,0,0,false, game, 0)
            rc:Disconnect()
        end)
        task.delay(0.20, function() S.DidParry = false end)
    end

    -- Multi-frame closing speed history (5 frames, smoothed)
    local posHist = {}  -- {dist, time}
    local MAX_HIST = 5

    local function pushHist(dist, t)
        table.insert(posHist, {d=dist, t=t})
        if #posHist > MAX_HIST then table.remove(posHist, 1) end
    end

    local function smoothClosing(curDist, curTime)
        if #posHist < 2 then return 0 end
        local oldest = posHist[1]
        local dt = curTime - oldest.t
        if dt <= 0 then return 0 end
        return (oldest.d - curDist) / dt   -- studs/sec, positive = approaching
    end

    -- Direction reversal watcher: re-arms DidParry the frame ball bounces
    local lastVelDir = Vector3.zero
    PremiumConn.DirWatch = RunService.PreSimulation:Connect(function()
        local b = GetBall(); if not b then return end
        local v = GetVel(b)
        if v.Magnitude > 2 and lastVelDir.Magnitude > 0 then
            if v.Unit:Dot(lastVelDir.Unit) < -0.5 then
                S.DidParry = false   -- ball reversed = re-arm instantly
            end
        end
        if v.Magnitude > 0.5 then lastVelDir = v end
    end)

    PremiumConn.Parry = RunService.PreSimulation:Connect(function()
        local Ball = GetBall()
        if not Ball then posHist={}; return end
        local HRP = GetHRP(); if not HRP then return end

        local BPos  = Ball.Position
        local HPos  = HRP.Position
        local Dist  = (HPos - BPos).Magnitude
        local Vel   = GetVel(Ball)
        local Speed = Vel.Magnitude
        local now   = os.clock()

        -- Auto-face if enabled
        if P.AutoFace then
            pcall(function()
                HRP.CFrame = CFrame.lookAt(HPos, Vector3.new(BPos.X,HPos.Y,BPos.Z))
            end)
        end

        -- ── EMERGENCY ────────────────────────────────────────────
        -- God Emergency (premium): fires at 3 studs — tighter than free's 6
        -- Standard emergency: fires at 6 studs like free
        if not S.DidParry then
            local eDist = P.GodEmergency and 3 or S.EmergencyDist
            if Dist <= eDist then
                PremiumFire(); posHist={}; return
            end
        end

        if Ball:GetAttribute("target") ~= Plr.Name then posHist={}; return end
        if S.DidParry then return end
        if Speed < 1 then
            if Dist <= 5 then PremiumFire() end
            return
        end

        pushHist(Dist, now)

        -- ── SPEED BOOST DETECTION ────────────────────────────────
        -- Track last 3 frames of speed. If ball accelerated >25%,
        -- it got a speed boost — increase fireAt to compensate.
        table.insert(speedHist, Speed)
        if #speedHist > 3 then table.remove(speedHist, 1) end
        local effectiveSpeed = Speed
        if P.SpeedBoostDetect and #speedHist >= 2 then
            local oldest = speedHist[1]
            if oldest > 0 and Speed / oldest > 1.25 then
                -- Ball accelerated >25% — treat as if going faster
                effectiveSpeed = Speed * 1.15
            end
        end

        -- ── CORE: same formula as free but tighter hitbox ────────
        -- Free:    fireAt = 6.0 + (PingMs/2000)*Speed  → 6 studs on server
        -- Premium: fireAt = PHT + (PingMs/2000)*Speed  → PHT studs (default 4.5)
        -- Fires later than free = more precise = never a pre-click
        local hbox   = P.HitboxTarget or 4.5
        local fireAt = hbox + (PingMs / 2000) * effectiveSpeed
        if Dist <= fireAt then
            PremiumFire(); return
        end

        -- ── VELOCITY EXTRAPOLATION ────────────────────────────────
        -- Predict where ball will be next frame (1/60s ahead).
        -- If THAT position is within fireAt, fire now — compensates
        -- the 1-frame processing lag that free users eat.
        if Speed > 1 then
            local nextDist   = (HPos - (BPos + Vel*(1/60))).Magnitude
            local nextFireAt = hbox + (PingMs / 2000) * effectiveSpeed
            if nextDist <= nextFireAt then
                PremiumFire(); return
            end
        end

        -- ── MULTI-FRAME ANTICURVE ─────────────────────────────────
        -- 5-frame smoothed closing speed vs free's single-frame delta.
        -- Stable on laggy servers, catches slow curves free misses entirely.
        if P.CurveCrusher or S.AntiCurve then
            local sc = smoothClosing(Dist, now)
            if sc > 5 then
                local curveFireAt = hbox + (PingMs / 2000) * sc
                if Dist <= curveFireAt then
                    PremiumFire()
                end
            end
        end
    end)
end

local function StopPremiumEngine()
    for _, c in pairs(PremiumConn) do if c then c:Disconnect() end end
    PremiumConn = {}
    S.DidParry = false
    speedHist  = {}
end


