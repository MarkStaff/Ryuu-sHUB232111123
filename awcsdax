            local SlotStroke=Instance.new("UIStroke",SlotContainer); SlotStroke.Thickness=1.4; SlotStroke.Color=Color3.fromRGB(0,180,255); SlotStroke.Transparency=0.25

            -- 20 character slot cells
            local SLOT_COUNT=20
            local slotCells={}
            for i=1,SLOT_COUNT do
                local cell=Instance.new("Frame",SlotContainer)
                cell.AnchorPoint=Vector2.new(0,0.5); cell.Position=UDim2.new((i-1)/SLOT_COUNT,2,0.5,0); cell.Size=UDim2.new(1/SLOT_COUNT,-4,0,20)
                cell.BackgroundColor3=Color3.fromRGB(0,30,60); cell.BackgroundTransparency=0.3; cell.BorderSizePixel=0; cell.ZIndex=15
                Instance.new("UICorner",cell).CornerRadius=UDim.new(0,4)
                local cellChar=Instance.new("TextLabel",cell); cellChar.Size=UDim2.new(1,0,1,0); cellChar.BackgroundTransparency=1
                cellChar.Text="—"; cellChar.Font=Enum.Font.Code; cellChar.TextSize=11
                cellChar.TextColor3=Color3.fromRGB(0,80,120); cellChar.ZIndex=16
                slotCells[i]={frame=cell,lbl=cellChar}
            end

            -- Cursor frame (blinks between cells)
            local Cursor=Instance.new("Frame",SlotContainer); Cursor.AnchorPoint=Vector2.new(0,0.5); Cursor.Size=UDim2.new(0,2,0,22); Cursor.Position=UDim2.new(0,2,0.5,0)
            Cursor.BackgroundColor3=Color3.fromRGB(0,220,255); Cursor.BorderSizePixel=0; Cursor.ZIndex=17
            task.spawn(function()
                while Cursor.Parent do
                    pcall(function() Cursor.BackgroundTransparency=0 end); task.wait(0.5)
                    pcall(function() Cursor.BackgroundTransparency=1 end); task.wait(0.5)
                end
            end)

            -- Hidden real TextBox
            local HiddenInput=Instance.new("TextBox",Card2); HiddenInput.Size=UDim2.new(1,-64,0,36); HiddenInput.Position=UDim2.new(0,32,0,92)
            HiddenInput.BackgroundTransparency=1; HiddenInput.Text=""; HiddenInput.TextColor3=Color3.fromRGB(0,0,0)
            HiddenInput.TextTransparency=1; HiddenInput.PlaceholderText=""; HiddenInput.Font=Enum.Font.Code; HiddenInput.TextSize=11
            HiddenInput.ClearTextOnFocus=false; HiddenInput.ZIndex=18

            -- Update slot display whenever input changes
            local function UpdateSlots(text)
                local len=math.min(#text,SLOT_COUNT)
                local progress=len/SLOT_COUNT
                -- Color: empty=blue, filling=red→yellow→green
                for i=1,SLOT_COUNT do
                    local cell=slotCells[i]
                    if i<=len then
                        local ch=text:sub(i,i)
                        cell.lbl.Text=ch
                        local hue=math.clamp((i/len)*0.33,0,0.33)  -- red→green
                        cell.lbl.TextColor3=Color3.fromHSV(hue,1,1)
                        cell.frame.BackgroundColor3=Color3.fromHSV(hue,0.9,0.2)
                        cell.frame.BackgroundTransparency=0.1
                        local cStr=cell.frame:FindFirstChildOfClass("UIStroke")
                        if not cStr then cStr=Instance.new("UIStroke",cell.frame) end
                        cStr.Color=Color3.fromHSV(hue,1,1); cStr.Thickness=0.8; cStr.Transparency=0.3
                    else
                        cell.lbl.Text="—"; cell.lbl.TextColor3=Color3.fromRGB(0,60,100)
                        cell.frame.BackgroundColor3=Color3.fromRGB(0,20,45); cell.frame.BackgroundTransparency=0.4
                        local cStr=cell.frame:FindFirstChildOfClass("UIStroke")
                        if cStr then cStr:Destroy() end
                    end
                end
                -- Move cursor
                local cursorCell=math.min(len+1,SLOT_COUNT)
                local cx=(cursorCell-1)/SLOT_COUNT
                Cursor.Position=UDim2.new(cx,3,0.5,0)
                -- Update SlotStroke color based on fill progress
                SlotStroke.Color=Color3.fromHSV(math.clamp(progress*0.33,0,0.33),1,1)
            end

            HiddenInput:GetPropertyChangedSignal("Text"):Connect(function()
                local txt=HiddenInput.Text
                -- Beep on each keypress
                if #txt>0 then playSound(6042053626,0.15,1.2+#txt*0.02) end
                UpdateSlots(txt)
            end)

            -- Scan beam (sweeps left→right over input during verify)
            local ScanBeam=Instance.new("Frame",Card2); ScanBeam.Size=UDim2.new(0,4,0,36); ScanBeam.Position=UDim2.new(0,28,0,92); ScanBeam.ZIndex=19; ScanBeam.Visible=false
            ScanBeam.BackgroundColor3=Color3.fromRGB(0,240,255); ScanBeam.BackgroundTransparency=0.3; ScanBeam.BorderSizePixel=0
            Instance.new("UICorner",ScanBeam).CornerRadius=UDim.new(1,0)
            local ScanGlow=Instance.new("UIGradient",ScanBeam); ScanGlow.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(0,0,0)),ColorSequenceKeypoint.new(0.5,Color3.fromRGB(0,255,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(0,0,0))}; ScanGlow.Rotation=90

            -- Status label
            local Status=Instance.new("TextLabel",Card2); Status.Size=UDim2.new(1,-64,0,18); Status.Position=UDim2.new(0,32,0,136)
            Status.BackgroundTransparency=1; Status.Text="◈  Awaiting authorization key..."; Status.Font=Enum.Font.GothamBold; Status.TextSize=11
            Status.TextColor3=Color3.fromRGB(0,160,210); Status.TextXAlignment=Enum.TextXAlignment.Left; Status.ZIndex=14

            -- Device ID label
            local DeviceLabel=Instance.new("TextLabel",Card2); DeviceLabel.Size=UDim2.new(1,-64,0,13); DeviceLabel.Position=UDim2.new(0,32,0,155)
            DeviceLabel.BackgroundTransparency=1; DeviceLabel.Font=Enum.Font.Code; DeviceLabel.TextSize=9
            DeviceLabel.TextColor3=Color3.fromRGB(40,100,140); DeviceLabel.TextXAlignment=Enum.TextXAlignment.Left; DeviceLabel.ZIndex=14
            pcall(function() DeviceLabel.Text="DEVICE  "..GetDeviceID():sub(1,22).."..." end)

