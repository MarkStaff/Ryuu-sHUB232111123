                            p.BorderSizePixel=0; p.ZIndex=25; Instance.new("UICorner",p).CornerRadius=UDim.new(1,0)
                            TweenService:Create(p,TweenInfo.new(1.1,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{
                                Position=UDim2.new(0.5,math.random(-250,250),0.5,math.random(-200,200)+60),
                                Size=UDim2.new(0,0,0,0),BackgroundTransparency=1}):Play()
                            Debris:AddItem(p,1.4)
                        end)
                    end

                    -- Full-screen success flash
                    local sFlash=Instance.new("Frame",KSG); sFlash.Size=UDim2.new(1,0,1,0); sFlash.BackgroundColor3=Color3.fromRGB(60,255,140); sFlash.BackgroundTransparency=0.6; sFlash.ZIndex=30
                    TweenService:Create(sFlash,TweenInfo.new(0.4),{BackgroundTransparency=1}):Play(); Debris:AddItem(sFlash,0.8)

                    PremiumUnlocked=true; PremiumActive=true
                    task.spawn(RemovePremiumLock)
                    Rayfield:Notify({Title="✨ Premium Activated",Content="Full access granted. Enjoy Ryuu V2 Premium.",Duration=6,Image=4483362458})

                    if S.AutoParry then
                        StopEngine(); task.wait(0.08); P.AutoParry=true; StartPremiumEngine()
                    end

                    task.wait(2.0); closeScanner()
                else
                    -- ── FAILURE SEQUENCE ───────────────────────────
                    playSound(6042053626,0.7,0.7)
                    Status.Text=result=="locked_other" and "◈  DEVICE MISMATCH — ACCESS DENIED" or "◈  INVALID KEY — AUTHORIZATION FAILED"
                    Status.TextColor3=Color3.fromRGB(255,60,60)

                    TweenService:Create(cardStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(220,50,50)}):Play()
                    TweenService:Create(orbStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(255,80,80)}):Play()
                    TweenService:Create(SlotStroke,TweenInfo.new(0.2),{Color=Color3.fromRGB(220,50,50)}):Play()

                    -- Update all slot cells to red
                    for _,cell in ipairs(slotCells) do
                        if cell.lbl.Text~="—" then
                            TweenService:Create(cell.lbl,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(255,60,60)}):Play()
                            TweenService:Create(cell.frame,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(60,0,0)}):Play()
                        end
                    end

                    -- Fail flash + shake
                    local fFlash=Instance.new("Frame",KSG); fFlash.Size=UDim2.new(1,0,1,0); fFlash.BackgroundColor3=Color3.fromRGB(220,30,30); fFlash.BackgroundTransparency=0.65; fFlash.ZIndex=30
                    TweenService:Create(fFlash,TweenInfo.new(0.3),{BackgroundTransparency=1}):Play(); Debris:AddItem(fFlash,0.7)
                    for i=1,8 do task.delay((i-1)*0.045,function() Card2.Position=UDim2.new(0.5,(i%2==0 and 10 or -10),0.5,60+(i%2==0 and 4 or -4)) end) end
                    task.delay(0.4,function() Card2.Position=UDim2.new(0.5,0,0.5,60) end)

                    task.wait(1.8)
                    -- Reset slots to neutral
                    for _,cell in ipairs(slotCells) do
                        TweenService:Create(cell.lbl,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(0,60,100)}):Play()
                        TweenService:Create(cell.frame,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(0,20,45)}):Play()
                    end
                    cardStroke.Color=Color3.fromRGB(0,200,255)
                    orbStroke.Color=Color3.fromRGB(80,220,255)
                    HiddenInput.Text=""; HiddenInput.TextEditable=true; VerifyBtn.Active=true
                    Status.Text="◈  Try again..."; Status.TextColor3=Color3.fromRGB(0,160,210)
                end
            end

            VerifyBtn.MouseButton1Click:Connect(doVerify)
            HiddenInput.FocusLost:Connect(function(enter) if enter then doVerify() end end)
            -- Auto-focus the hidden input when card appears
            task.delay(0.6,function() pcall(function() HiddenInput:CaptureFocus() end) end)
        end)
    end
})

